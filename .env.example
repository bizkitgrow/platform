# Supabase (SSOT PostgreSQL Database)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Payment Gateways (Duitku - Phase 2)
DUITKU_MERCHANT_CODE=D12345
DUITKU_API_KEY=your-duitku-sandbox-api-key
DUITKU_CALLBACK_URL=https://bizkitgrow.vercel.app/api/payment/duitku-callback

# Communication Gateways (Phase 2)
FONNTE_TOKEN=
RESEND_API_KEY=

# Autonomous AI Providers (Multi-Provider Key Pool)
GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key
