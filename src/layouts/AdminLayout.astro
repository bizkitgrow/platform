---
import { SEO } from 'astro-seo';
import systemArchitecture from '../../system_architecture.json';
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
const brandName = systemArchitecture.tenant_settings.brand_name;
const safeTitle = `${title} | ${brandName} CMS`;
---

<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />

  <SEO 
    title={safeTitle} 
    noindex={true}
    nofollow={true}
  />

  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600&family=Outfit:wght@800;900&family=Plus+Jakarta+Sans:wght@400;500;600&display=swap" rel="stylesheet" />

  <style>
    :root {
      --canvas: #000000;
      --surface: #0a0a0a;
      --font-mono: 'JetBrains Mono', monospace;
      --font-heading: 'Outfit', sans-serif;
      --font-body: 'Plus Jakarta Sans', sans-serif;
    }
    body {
      font-family: var(--font-body);
      background: var(--canvas);
    }
  </style>
</head>
<body class="bg-canvas dark:bg-canvas text-text_primary antialiased">
  
  <nav class="fixed top-0 z-50 w-full bg-black border-b border-gray-700 dark:bg-black dark:border-gray-700">
    <div class="px-3 py-3 lg:px-5 lg:pl-3">
      <div class="flex items-center justify-between">
        <div class="flex items-center justify-start rtl:justify-end">
          <button data-drawer-target="logo-sidebar" data-drawer-toggle="logo-sidebar" aria-controls="logo-sidebar" type="button" class="inline-flex items-center p-2 text-sm text-gray-500 rounded-lg sm:hidden hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-gray-200 dark:text-gray-400 dark:hover:bg-gray-700 dark:focus:ring-gray-600">
              <span class="sr-only">Open sidebar</span>
              <svg class="w-6 h-6" aria-hidden="true" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                 <path clip-rule="evenodd" fill-rule="evenodd" d="M2 4.75A.75.75 0 012.75 4h14.5a.75.75 0 010 1.5H2.75A.75.75 0 012 4.75zm0 10.5a.75.75 0 01.75-.75h7.5a.75.75 0 010 1.5h-7.5a.75.75 0 01-.75-.75zM2 10a.75.75 0 01.75-.75h14.5a.75.75 0 010 1.5H2.75A.75.75 0 012 10z"></path>
              </svg>
           </button>
          <a href="/admin" class="flex ms-2 md:me-24">
            <span class="font-heading text-xl font-black tracking-widest text-white uppercase">BIZKITGROW<span class="text-brand_cta">_</span> <span class="text-xs text-gray-500 tracking-wider">CMS</span></span>
          </a>
        </div>
      </div>
    </div>
  </nav>

  <aside id="logo-sidebar" class="fixed top-0 left-0 z-40 w-64 h-screen pt-20 transition-transform -translate-x-full bg-black border-r border-gray-700 sm:translate-x-0 dark:bg-black dark:border-gray-700" aria-label="Sidebar">
     <div class="h-full px-3 pb-4 overflow-y-auto bg-black dark:bg-black">
        <ul class="space-y-2 font-medium font-mono text-xs uppercase tracking-widest">
           <li>
              <a href="/admin" class="flex items-center p-2 text-gray-300 rounded-lg dark:text-white hover:bg-gray-800 dark:hover:bg-gray-700 group">
                 <span class="ms-3">Dashboard</span>
              </a>
           </li>
           <li>
              <a href="/admin/posts" class="flex items-center p-2 text-gray-300 rounded-lg dark:text-white hover:bg-gray-800 dark:hover:bg-gray-700 group">
                 <span class="flex-1 ms-3 whitespace-nowrap">Posts</span>
              </a>
           </li>
           <li>
              <a href="/admin/rss" class="flex items-center p-2 text-gray-300 rounded-lg dark:text-white hover:bg-gray-800 dark:hover:bg-gray-700 group">
                 <span class="flex-1 ms-3 whitespace-nowrap">RSS Feeds</span>
              </a>
           </li>
           <li>
              <a href="/admin/logs" class="flex items-center p-2 text-gray-300 rounded-lg dark:text-white hover:bg-gray-800 dark:hover:bg-gray-700 group">
                 <span class="flex-1 ms-3 whitespace-nowrap">Logs</span>
              </a>
           </li>
        </ul>
     </div>
  </aside>

  <div class="p-4 sm:ml-64 pt-20 bg-canvas min-h-screen">
     <slot />
  </div>

  <script>
    import 'flowbite';
  </script>
</body>
</html>
