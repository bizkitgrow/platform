                <li><a href="/reputation#ai-responder" class="hover:text-brand_cta block">AI RESPONDER</a></li>
                <li><a href="/reputation#local-leads" class="hover:text-brand_cta block">LOCAL LEADS</a></li>
              </ul>
            </div>
            <div>
              <a href="/intelligence" class="block font-heading text-xs font-black text-black uppercase tracking-tight mb-3 border-b-2 border-black pb-1 hover:text-brand_cta">Intelligence</a>
              <ul class="space-y-2 text-[10px] font-mono text-gray-600 font-bold">
