                <li><a href="/esim#global-esim" class="hover:text-brand_cta block">GLOBAL ESIM</a></li>
              </ul>
            </div>
            <div>
              <a href="/reputation" class="block font-heading text-xs font-black text-black uppercase tracking-tight mb-3 border-b-2 border-black pb-1 hover:text-brand_cta">Reputation</a>
