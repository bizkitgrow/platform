---
import brandManifest from '../../config/brand_manifest.json';
import systemArchitecture from '../../system_architecture.json';
import uxDesignToken from '../../ux_design_token.json';
import '@astrouxds/tokens/dist/css/index.css';

interface Props {
  title: string;
  description: string;
  canonicalUrl: string;
}

const { title = '', description = '', canonicalUrl = '' } = Astro.props;
const brandName = systemArchitecture.tenant_settings.brand_name;
const tokens = uxDesignToken.design_system.tokens;
const safeTitle = title || '';
const safeDescription = description || '';
const safeCanonicalUrl = canonicalUrl || Astro.url.href;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  
  <title>{safeTitle} | {brandName}</title>
  <meta name="description" content={safeDescription} />
  <link rel="canonical" href={safeCanonicalUrl} />

  <!-- OpenGraph Tags compliant with Naver / B2B Authority -->
  <meta property="og:site_name" content={brandName} />
  <meta property="og:title" content={safeTitle.slice(0, 40)} />
  <meta property="og:description" content={safeDescription.slice(0, 80)} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={safeCanonicalUrl} />
  <meta property="og:image" content={new URL('/og-image.webp', safeCanonicalUrl).href} />
  
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={safeTitle.slice(0, 40)} />
  <meta name="twitter:description" content={safeDescription.slice(0, 80)} />
  <meta name="twitter:image" content={new URL('/og-image.webp', safeCanonicalUrl).href} />

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/favicon.png" />

  <!-- Verification Tags -->
  <meta name="naver-site-verification" content="verified_bizkitgrow" />

  <!-- Google Fonts Inter -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />



  <!-- Dynamic JSON-LD Schema Injection Slot -->
  <slot name="schema" />

  <style define:vars={{
    fontFamily: tokens.typography.family,
    headingFamily: tokens.typography.heading_family
  }}>
    body {
      font-family: var(--fontFamily);
    }
    h1, h2, h3, h4, h5, h6 {
      font-family: var(--headingFamily);
      letter-spacing: -0.02em;
    }
  </style>
</head>
<body class="antialiased selection:bg-interactive-hover selection:text-text-inverse bg-background-base text-text-primary min-h-screen flex flex-col">
  <!-- Dynamic Navigation Header -->
  <header class="border-b border-border-subtle sticky top-0 bg-background-surface/80 backdrop-blur-md z-50">
    <div class="max-w-[1280px] mx-auto px-6 h-16 flex items-center justify-between">
      <a href="/" class="text-xl font-extrabold tracking-tight text-text-primary flex items-center gap-2 hover:opacity-90">
        <span class="w-8 h-8 rounded-lg bg-interactive-normal flex items-center justify-center text-text-inverse text-base">b</span>
        {brandName}
      </a>
      <nav class="hidden md:flex items-center gap-8 text-sm font-medium text-text-secondary">
        <a href="/" class="hover:text-text-primary transition-colors">Platform</a>
        <a href="/esim/united-states" class="hover:text-text-primary transition-colors">Connectivity</a>
        <a href="/reputation/new-york" class="hover:text-text-primary transition-colors">Reputation</a>
        <a href="/solutions/crm-system" class="hover:text-text-primary transition-colors">Solutions</a>
        <a href="/blog" class="hover:text-text-primary transition-colors">Intelligence</a>
      </nav>
      <div class="flex items-center gap-4">
        <a href="#waitlist" class="h-9 px-4 inline-flex items-center justify-center rounded-lg bg-interactive-normal hover:bg-interactive-hover text-text-inverse text-xs font-semibold tracking-wide transition-colors">
          Initialize System
        </a>
      </div>
    </div>
  </header>

  <!-- Main View Frame -->
  <div class="flex-grow">
    <slot />
  </div>

  <!-- Corporate Footer -->
  <footer class="border-t border-border-subtle bg-background-surface py-12 mt-20">
    <div class="max-w-[1280px] mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="text-sm text-text-secondary">
        © {new Date().getFullYear()} {systemArchitecture.tenant_settings.parent_company_copyright}. All operational assets secure.
      </div>
      <div class="flex gap-6 text-xs text-text-secondary">
        <a href="/terms" class="hover:underline text-text-primary">Terms of Authority</a>
        <a href="/privacy" class="hover:underline text-text-primary">Privacy Perimeter</a>
        <a href={`mailto:${systemArchitecture.tenant_settings.support_email}`} class="hover:underline text-text-primary">Operations Support</a>
      </div>
    </div>
  </footer>

  <!-- GTM Lazy Hydration Optimization -->
  <script is:inline>
    window.addEventListener('load', () => {
      if ('requestIdleCallback' in window) {
        requestIdleCallback(() => {
          // Lazy init GTM Container
          console.log('[Telemetry] Lazy-hydrating GTM trackers...');
        });
      } else {
        setTimeout(() => {
          console.log('[Telemetry] Hydrating GTM trackers...');
        }, 3000);
      }
    });
  </script>

  <!-- Lenis Smooth Scroll Engine -->
  <script>
    import Lenis from 'lenis';
    const lenis = new Lenis({
      duration: 1.2,
      easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      infinite: false,
    });

    function raf(time: number) {
      lenis.raf(time);
      requestAnimationFrame(raf);
    }
    requestAnimationFrame(raf);
  </script>
</body>
</html>
