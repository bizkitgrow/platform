---
import brandManifest from '../../config/brand_manifest.json';
import systemArchitecture from '../../system_architecture.json';
import uxDesignToken from '../../ux_design_token.json';

interface Props {
  title: string;
  description: string;
  canonicalUrl: string;
}

const { title, description, canonicalUrl } = Astro.props;
const brandName = systemArchitecture.tenant_settings.brand_name;
const tokens = uxDesignToken.design_system.tokens;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  
  <title>{title} | {brandName}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  <!-- OpenGraph Tags compliant with Naver / B2B Authority -->
  <meta property="og:site_name" content={brandName} />
  <meta property="og:title" content={title.slice(0, 40)} />
  <meta property="og:description" content={description.slice(0, 80)} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content="/og-image-default.jpg" />
  
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title.slice(0, 40)} />
  <meta name="twitter:description" content={description.slice(0, 80)} />

  <!-- Verification Tags -->
  <meta name="naver-site-verification" content="verified_bizkitgrow" />

  <!-- Google Fonts Inter -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

  <!-- Dynamic JSON-LD Schema Injection Slot -->
  <slot name="schema" />

  <style define:vars={{
    canvas: tokens.colors.canvas,
    canvasAccent: tokens.colors.canvas_accent,
    textPrimary: tokens.colors.text_primary,
    textSecondary: tokens.colors.text_secondary,
    bordersSubtle: tokens.colors.borders_subtle,
    brandCta: tokens.colors.brand_cta,
    fontFamily: tokens.typography.family
  }}>
    body {
      background-color: var(--canvas);
      color: var(--textPrimary);
      font-family: var(--fontFamily);
    }
  </style>
</head>
<body class="antialiased selection:bg-emerald-100 selection:text-emerald-900 min-h-screen flex flex-col">
  <!-- Dynamic Navigation Header -->
  <header class="border-b border-[#E2E8F0] sticky top-0 bg-white/80 backdrop-blur-md z-50">
    <div class="max-w-[1280px] mx-auto px-6 h-16 flex items-center justify-between">
      <a href="/" class="text-xl font-extrabold tracking-tight text-[#0F172A] flex items-center gap-2 hover:opacity-90">
        <span class="w-8 h-8 rounded-lg bg-emerald-600 flex items-center justify-center text-white text-base">b</span>
        {brandName}
      </a>
      <nav class="hidden md:flex items-center gap-8 text-sm font-medium text-[#475569]">
        <a href="/" class="hover:text-[#0F172A] transition-colors">Platform</a>
        <a href="/esim/united-states" class="hover:text-[#0F172A] transition-colors">Connectivity</a>
        <a href="/reputation/new-york" class="hover:text-[#0F172A] transition-colors">Reputation</a>
        <a href="/solutions/crm-system" class="hover:text-[#0F172A] transition-colors">Solutions</a>
      </nav>
      <div class="flex items-center gap-4">
        <a href="#waitlist" class="h-9 px-4 inline-flex items-center justify-center rounded-lg bg-emerald-600 hover:bg-emerald-700 text-white text-xs font-semibold tracking-wide transition-colors">
          Initialize System
        </a>
      </div>
    </div>
  </header>

  <!-- Main View Frame -->
  <div class="flex-grow">
    <slot />
  </div>

  <!-- Corporate Footer -->
  <footer class="border-t border-[#E2E8F0] bg-[#F8FAFC] py-12 mt-20">
    <div class="max-w-[1280px] mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="text-sm text-[#475569]">
        © {new Date().getFullYear()} {systemArchitecture.tenant_settings.parent_company_copyright}. All operational assets secure.
      </div>
      <div class="flex gap-6 text-xs text-[#475569]">
        <a href="#" class="hover:underline">Terms of Authority</a>
        <a href="#" class="hover:underline">Privacy Perimeter</a>
        <a href={`mailto:${systemArchitecture.tenant_settings.support_email}`} class="hover:underline">Operations Support</a>
      </div>
    </div>
  </footer>

  <!-- GTM Lazy Hydration Optimization -->
  <script is:inline>
    window.addEventListener('load', () => {
      if ('requestIdleCallback' in window) {
        requestIdleCallback(() => {
          // Lazy init GTM Container
          console.log('[Telemetry] Lazy-hydrating GTM trackers...');
        });
      } else {
        setTimeout(() => {
          console.log('[Telemetry] Hydrating GTM trackers...');
        }, 3000);
      }
    });
  </script>

  <!-- Lenis Smooth Scroll Engine -->
  <script>
    import Lenis from 'lenis';
    const lenis = new Lenis({
      duration: 1.2,
      easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      infinite: false,
    });

    function raf(time: number) {
      lenis.raf(time);
      requestAnimationFrame(raf);
    }
    requestAnimationFrame(raf);
  </script>
</body>
</html>
