          </div>
        </li>
        <li>
          <a href="/blog" class={`block py-2 px-3 md:p-0 ${Astro.url.pathname.startsWith('/blog') ? 'text-brand_cta' : 'text-text_secondary'} md:hover:text-brand_cta`}>RESOURCES</a>
        </li>
      </ul>
    </div>
    </div>
  </nav>

  <main id="content" class="flex-grow pt-8">
