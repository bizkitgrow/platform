---
export const prerender = false;

import { Image } from 'astro:assets';
import { desc } from 'drizzle-orm';
import MarketIntelligenceWidget from '../../components/MarketIntelligenceWidget.astro';
import { db } from '../../db/client';
import { posts as postsTable } from '../../db/schema';
import BaseLayout from '../../layouts/BaseLayout.astro';

const currentUrl = Astro.site
  ? new URL('/blog', Astro.site).toString()
  : 'https://bizkitgrow.vercel.app/blog';

const pillarLabels: Record<string, string> = {
  esim_data_plans: 'TEAM ROAMING',
  reputation_management: 'CLIENT REVIEWS',
  ai_business_tools_suite: 'CLIENT PORTALS',
  general: 'BUSINESS GUIDES',
};

let dbPosts: any[] = [];
try {
  dbPosts = await db.select().from(postsTable).orderBy(desc(postsTable.createdAt)).limit(24);
} catch (err: any) {
  console.error('Database query failed, using fallback:', err.message);
}

const fallbackPosts = [
  {
    title: 'The Future of Global Connectivity for Remote Teams',
    slug: 'the-future-of-connectivity-and-mobility',
    excerpt:
      'Enterprise eSIM infrastructure is replacing legacy SIM provisioning — here is what B2B operators need to know in 2026.',
    readingTime: '3 min read',
    createdAt: 'Jul 4, 2026',
    pillar: 'esim_data_plans',
    originalImage: null,
  },
  {
    title: 'Google Rewrites the Search Interface',
    slug: 'google-rewrites-search-2026',
    excerpt:
      'The largest upgrade to Google Search in 25 years is reshaping local SEO authority. What every B2B operator must act on now.',
    readingTime: '5 min read',
    createdAt: 'Jul 4, 2026',
    pillar: 'ai_business_tools_suite',
    originalImage: null,
  },
];

const posts =
  dbPosts.length > 0
    ? dbPosts.map((p) => ({
        title: p.title,
        slug: p.slug,
        excerpt: p.metaDesc || 'Read the complete analysis from the Bizkitgrow intelligence feed.',
        readingTime: `${Math.max(2, Math.ceil((p.content?.length || 1000) / 1500))} min read`,
        createdAt: p.createdAt
          ? new Date(p.createdAt).toLocaleDateString('en-US', {
              month: 'short',
              day: 'numeric',
              year: 'numeric',
            })
          : 'Jul 4, 2026',
        pillar: p.targetProductSku || 'ai_business_tools_suite',
        originalImage: p.originalImage,
      }))
    : fallbackPosts;

// BlogPosting list JSON-LD for AEO
const blogListSchema = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'Bizkitgrow Intelligence Feed',
  url: currentUrl,
  description:
    'Expert insights on global connectivity, local SEO dominance, and agency automation.',
  blogPost: posts.slice(0, 5).map((p) => ({
    '@type': 'BlogPosting',
    headline: p.title,
    url: Astro.site
      ? new URL(`/blog/${p.slug}`, Astro.site).toString()
      : `https://bizkitgrow.vercel.app/blog/${p.slug}`,
    datePublished: p.createdAt,
  })),
};
---

<BaseLayout
  title="Intelligence Feed | Bizkitgrow"
  description="Expert insights, live market data, TradingView charts, and B2B growth strategies — updated daily by the Bizkitgrow team."
  canonicalUrl={currentUrl}
>
  <script type="application/ld+json" slot="schema" is:inline set:html={JSON.stringify(blogListSchema)} />

  <!-- schema.org/Dataset for AEO/GEO — AI Overview authority signal -->
  <script type="application/ld+json" slot="schema" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "Dataset",
    "name": "Bizkitgrow Live Market Intelligence Feed",
    "description": "Real-time cryptocurrency prices, global equity market data, and macro intelligence — aggregated from CoinGecko, TradingView, and Finnhub APIs.",
    "url": "https://bizkitgrow.vercel.app/blog#market",
    "creator": { "@type": "Organization", "name": "Bizkitgrow" },
    "license": "https://creativecommons.org/licenses/by/4.0/",
    "variableMeasured": ["Cryptocurrency Price", "Market Capitalization", "24h Price Change", "Trading Volume", "Market Intelligence"],
    "temporalCoverage": "2024/..",
    "distribution": {
      "@type": "DataDownload",
      "encodingFormat": "application/json",
      "contentUrl": "https://bizkitgrow.vercel.app/api/v1/telemetry"
    }
  }
  </script>

  <!-- ── TICKER TAPE — Persistent, always-on, full-width (above container padding) ───────────────── -->
  <!-- TradingView Ticker Tape: injected via JS to avoid Astro JSON-in-script parse error -->
  <div id="tv-ticker-wrap" class="w-full border-b-2 border-black overflow-hidden bg-white" aria-label="Live market ticker tape" style="height:52px">
    <div id="tv-ticker-container"></div>
  </div>
  <script is:inline>
    (function () {
      var cfg = {
        symbols: [
          { proName: 'BITSTAMP:BTCUSD', title: 'Bitcoin' },
          { proName: 'BITSTAMP:ETHUSD', title: 'Ethereum' },
          { proName: 'BINANCE:SOLUSDT', title: 'Solana' },
          { proName: 'BINANCE:XRPUSDT', title: 'XRP' },
          { proName: 'BINANCE:BNBUSDT', title: 'BNB' },
          { proName: 'FOREXCOM:SPXUSD', title: 'S&P 500' },
          { proName: 'NASDAQ:AAPL', title: 'Apple' },
          { proName: 'NASDAQ:NVDA', title: 'NVIDIA' },
          { proName: 'NASDAQ:TSLA', title: 'Tesla' },
          { proName: 'TVC:GOLD', title: 'Gold' },
          { proName: 'FX:EURUSD', title: 'EUR/USD' },
          { proName: 'FOREXCOM:DJI', title: 'Dow Jones' }
        ],
        showSymbolLogo: true,
        isTransparent: false,
        displayMode: 'adaptive',
        colorTheme: 'light',
        locale: 'en'
      };
      var s = document.createElement('script');
      s.src = 'https://s3.tradingview.com/external-embedding/embed-widget-ticker-tape.js';
      s.async = true;
      s.textContent = JSON.stringify(cfg);
      var container = document.getElementById('tv-ticker-container');
      if (container) container.appendChild(s);
    })();
  </script>

  <main class="max-w-7xl mx-auto px-6 py-16">

    <!-- Header -->
    <header class="mb-12 border-b border-borders_subtle pb-8">
      <div class="font-['JetBrains_Mono'] text-[10px] text-text_secondary uppercase tracking-widest mb-4">
        [ RESOURCES & INSIGHTS // LIVE ]
      </div>
      <h1 class="font-['Outfit'] text-5xl md:text-7xl font-black text-text_primary uppercase tracking-tight">
        Growth &<br />Operations.
      </h1>
      <p class="mt-4 text-sm text-text_secondary max-w-xl leading-relaxed">
        Practical guides and resources on managing remote team connectivity, boosting local search visibility, and streamlining agency billing operations.
      </p>
    </header>

    <!-- Search Engine & Filter -->
    <div class="mb-12 border-4 border-black bg-white p-6 shadow-brutal flex flex-col md:flex-row gap-4 justify-between items-center">
      <div class="w-full md:w-2/3 relative" id="search-container">
        <span class="absolute inset-y-0 left-0 flex items-center pl-4 font-black text-black">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="square" stroke-linejoin="miter" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
        </span>
        <input 
          type="search" 
          id="resource-search"
          placeholder="SEARCH ARTICLES..." 
          class="w-full bg-canvas_accent border-2 border-black pl-12 pr-4 py-4 font-mono text-sm uppercase font-bold text-black placeholder-gray-500 focus:outline-none focus:border-brand_cta focus:ring-0 transition-colors"
          aria-label="Search articles"
        />
      </div>
      <div class="w-full md:w-1/3 flex justify-end gap-2 overflow-x-auto pb-2 md:pb-0 scrollbar-hide">
        <button class="filter-btn active bg-black text-white px-5 py-3 font-mono text-[10px] font-bold uppercase tracking-widest shrink-0 border-2 border-black hover:bg-brand_cta hover:text-black transition-colors" data-filter="news" aria-label="Show articles">ARTICLES</button>
        <button class="filter-btn bg-white text-black px-5 py-3 font-mono text-[10px] font-bold uppercase tracking-widest shrink-0 border-2 border-black hover:bg-brand_cta transition-colors" data-filter="market" aria-label="Show live market terminal">MARKET</button>
      </div>
    </div>

    <div id="content-wrapper">
      <!-- Posts Grid (NEWS) -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="posts-grid">
        {posts.map((post, i) => {
          const fallbackSeed = post.title.replace(/[^a-zA-Z0-9]/g, '').toLowerCase() || 'bizkitgrow';
          const heroImageUrl = post.originalImage && post.originalImage.trim() !== '' 
            ? post.originalImage 
            : `https://picsum.photos/seed/${fallbackSeed}/600/375`;
          
          const label = pillarLabels[post.pillar] || pillarLabels.general;

          return (
            <article
              class={`post-card border-2 border-black group hover:-translate-y-1 transition-transform bg-white rounded-none flex flex-col h-full shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:shadow-[6px_6px_0px_0px_rgba(13,148,136,1)] ${i >= 6 ? 'hidden post-card-hidden' : ''}`}
              data-title={post.title.toLowerCase()}
              data-pillar={post.pillar}
            >
              <div class="relative w-full aspect-[16/10] bg-gray-100 overflow-hidden border-b-2 border-black">
                <Image
                  src={heroImageUrl}
                  alt={post.title}
                  width={600}
                  height={375}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  inferSize={!heroImageUrl.startsWith('http')}
                  loading={i < 3 ? "eager" : "lazy"}
                />
                <div class="absolute top-3 left-3 bg-black text-white font-mono text-[8px] font-black uppercase tracking-widest px-2 py-0.5 border border-white">
                  {label}
                </div>
              </div>
              <div class="p-6 flex flex-col flex-grow">
                <div class="flex items-center gap-3 mb-3">
                  <span class="font-mono text-[9px] text-gray-500 uppercase tracking-wider font-bold">
                    {post.readingTime}
                  </span>
                </div>

                <h2 class="font-heading text-lg font-black text-black uppercase tracking-tight leading-snug mb-3 group-hover:text-brand_cta transition-colors">
                  <a href={`/blog/${post.slug}`} class="stretched-link">
                    {post.title}
                  </a>
                </h2>

                <p class="text-sm text-gray-700 leading-relaxed mb-6 flex-grow">
                  {post.excerpt}
                </p>

                <div class="flex items-center justify-between border-t-2 border-black pt-4 mt-auto">
                  <span class="font-mono text-[9px] text-gray-500 uppercase tracking-wider font-bold">
                    {post.createdAt}
                  </span>
                  <span class="font-mono text-[10px] text-brand_cta uppercase tracking-wider group-hover:text-black transition-colors font-black">
                    READ &rarr;
                  </span>
                </div>
              </div>
            </article>
          );
        })}

        <!-- Pagination Trigger (Load More) -->
        {posts.length > 6 && (
          <div id="posts-load-more-wrap" class="col-span-full text-center mt-12">
            <button 
              id="load-more-btn" 
              class="bg-white text-black border-2 border-black font-mono font-bold uppercase text-[10px] tracking-widest px-8 py-3 hover:bg-brand_cta transition-colors shadow-brutal active:translate-y-1 active:shadow-none"
              aria-label="Load more articles"
            >
              LOAD MORE ARTICLES &darr;
            </button>
          </div>
        )}
      </div>

      <!-- Market Intelligence Widget (MARKET tab) -->
      <div id="market-grid" style="display: none;" aria-live="polite">
        <MarketIntelligenceWidget />
      </div>
    </div>

    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const searchInput = document.getElementById('resource-search');
        const filterBtns = document.querySelectorAll('.filter-btn');
        const cards = document.querySelectorAll('.post-card');
        const postsGrid = document.getElementById('posts-grid');
        const marketGrid = document.getElementById('market-grid');
        const searchContainer = document.getElementById('search-container');
        const loadMoreWrap = document.getElementById('posts-load-more-wrap');

        let currentTab = 'news';
        let searchQuery = '';

        function activateTab(tab) {
          currentTab = tab;
          filterBtns.forEach(b => {
            const isActive = b.getAttribute('data-filter') === tab;
            b.classList.toggle('bg-black', isActive);
            b.classList.toggle('text-white', isActive);
            b.classList.toggle('bg-white', !isActive);
            b.classList.toggle('text-black', !isActive);
            b.setAttribute('aria-pressed', isActive ? 'true' : 'false');
          });
          render();
          // Update URL hash without scrolling
          if (history.replaceState) {
            history.replaceState(null, '', tab === 'market' ? '#market' : '#');
          }
        }

        function render() {
          if (currentTab === 'market') {
            postsGrid.style.display = 'none';
            marketGrid.style.display = 'block';
            searchContainer.style.display = 'none';
          } else {
            postsGrid.style.display = 'grid';
            marketGrid.style.display = 'none';
            searchContainer.style.display = 'block';
            
            // Apply search filter and reset load more if searching
            let visibleCount = 0;
            cards.forEach((card, index) => {
              const title = card.getAttribute('data-title') || '';
              const matchesSearch = title.includes(searchQuery);
              
              if (matchesSearch) {
                visibleCount++;
                // If searching, show all matches. Otherwise, enforce the first 6 limit.
                if (searchQuery !== '') {
                  card.classList.remove('hidden');
                } else {
                  if (visibleCount <= 6) {
                    card.classList.remove('hidden');
                  } else {
                    card.classList.add('hidden');
                    card.classList.add('post-card-hidden');
                  }
                }
              } else {
                card.classList.add('hidden');
              }
            });

            if (loadMoreWrap) {
              loadMoreWrap.style.display = (searchQuery === '' && visibleCount > 6) ? 'block' : 'none';
            }
          }
        }

        if (searchInput) {
          searchInput.addEventListener('input', (e) => {
            searchQuery = e.target.value.toLowerCase();
            render();
          });
        }

        filterBtns.forEach(btn => {
          btn.addEventListener('click', () => {
            activateTab(btn.getAttribute('data-filter'));
          });
        });

        // Load More button click handler
        const loadMoreBtn = document.getElementById('load-more-btn');
        if (loadMoreBtn) {
          loadMoreBtn.addEventListener('click', () => {
            const hiddenCards = document.querySelectorAll('.post-card-hidden');
            hiddenCards.forEach(c => {
              c.classList.remove('hidden', 'post-card-hidden');
            });
            if (loadMoreWrap) loadMoreWrap.style.display = 'none';
          });
        }

        // Handle #market hash on load (deep-link from homepage CTA)
        if (window.location.hash === '#market') {
          activateTab('market');
          setTimeout(() => {
            const el = document.getElementById('market-grid');
            if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }, 150);
        }
      });
    </script>

    {posts.length === 0 && (
      <div class="border border-borders_subtle p-16 text-center rounded-sm">
        <div class="font-['JetBrains_Mono'] text-[10px] text-text_secondary uppercase tracking-widest mb-3 font-bold">RESOURCES INITIALIZING</div>
        <p class="text-sm text-text_secondary">Resource pipeline is warming up. New resources will appear automatically after the next ingestion cycle.</p>
      </div>
    )}

  </main>
</BaseLayout>
