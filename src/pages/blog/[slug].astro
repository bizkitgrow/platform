---
import { Image } from 'astro:assets';
import { Redis } from '@upstash/redis';
import { and, eq, ne } from 'drizzle-orm';
import systemArchitecture from '../../../config/system_architecture.json';
import AGCParaphraser from '../../components/AGCParaphraser.astro';
import ResellPortalWidget from '../../components/ResellPortalWidget.astro';
import { db } from '../../db/client';
import { posts as postsTable, shortUrls } from '../../db/schema';
import BaseLayout from '../../layouts/BaseLayout.astro';

// Set public edge cache
Astro.response.headers.set('Cache-Control', 'public, max-age=0, s-maxage=3600');

export const prerender = false;

// Initialize Redis for url cache
const redis = Redis.fromEnv();

async function getOrCreateShortUrl(url: string, origin: string) {
  if (!url) return '';

  // Try reading from Upstash Redis cache first
  try {
    const cached = await redis.get(`shorturl:${url}`);
    if (cached && typeof cached === 'string') return cached;
  } catch (err) {
    console.warn('Redis shortUrl read failed:', err);
  }

  const encoder = new TextEncoder();
  const data = encoder.encode(url);
  const hashBuffer = await crypto.subtle.digest('SHA-1', data);
  const hashArray = Array.from(new Uint8Array(hashBuffer));
  const hash = hashArray
    .map((b) => b.toString(16).padStart(2, '0'))
    .join('')
    .slice(0, 6);

  const shorted = new URL(`/s/${hash}`, origin).toString();

  try {
    await db
      .insert(shortUrls)
      .values({ hash, originalUrl: url })
      .onConflictDoNothing({ target: shortUrls.hash });
  } catch (e) {
    console.warn('DB insert failed for shortUrl:', e);
  }

  try {
    // Cache the resolved URL in Redis mapping both ways
    await redis.set(`shorturl:${url}`, shorted);
    await redis.set(`shorturl-hash:${hash}`, url);
  } catch (e) {
    console.warn('Redis set failed for shortUrl:', e);
  }

  return shorted;
}

const { slug } = Astro.params;

let post: any = null;
const media: any = null;
let relatedPosts: any[] = [];
let aiMeta: any = {};

try {
  const fetchedPosts = await db
    .select()
    .from(postsTable)
    .where(eq(postsTable.slug, slug || ''))
    .limit(1);

  if (fetchedPosts.length > 0) {
    post = fetchedPosts[0];

    relatedPosts = await db
      .select()
      .from(postsTable)
      .where(
        and(
          eq(postsTable.targetProductSku, post.targetProductSku || 'ai_business_tools_suite'),
          ne(postsTable.id, post.id),
        ),
      )
      .limit(2);

    if (post.aiSummary && typeof post.aiSummary === 'object') {
      aiMeta = post.aiSummary;
    }
  }
} catch (err: any) {
  console.error('DB query failed:', err.message);
}

// Proper 404 redirect if post is not found
if (!post) {
  return Astro.redirect('/404');
}

if (relatedPosts.length < 2) {
  try {
    const skipId = post.id;
    const extra = await db
      .select()
      .from(postsTable)
      .where(ne(postsTable.id, skipId))
      .limit(2 - relatedPosts.length);
    relatedPosts = [...relatedPosts, ...extra];
  } catch {}
}

const activePost = post;
const mainContentRaw = activePost.originalContent || activePost.content || '';
const mainContent = mainContentRaw.replace(
  /<a([^>]+href="(?!#|\/)[^"]+")[^>]*>/gi,
  '<a$1 target="_blank" rel="noopener noreferrer">',
);
const wordCount = mainContent.replace(/<[^>]*>/g, '').split(/\s+/).length;
const readingTime = Math.max(2, Math.ceil(wordCount / 200));

// Dynamic CTA per pillar
const CTA_MAP: Record<string, { headline: string; body: string; cta: string; href: string }> = {
  esim_data_plans: {
    headline: 'Deploy Sovereign Connectivity',
    body: 'Instant global eSIM provisioning across 190+ countries with enterprise-grade encryption. Sub-420ms activation, zero contracts.',
    cta: 'CONFIGURE YOUR ESIM',
    href: '/esim/united-states',
  },
  reputation_management: {
    headline: 'Own the Local Search Grid',
    body: 'Automate Google Business Profile optimization and review capture sequences. Dominate high-value zip codes without volatile ad spend.',
    cta: 'ACTIVATE REPUTATION ENGINE',
    href: '/reputation/new-york',
  },
  ai_business_tools_suite: {
    headline: 'Initialize Agency Automation',
    body: 'Consolidate invoicing, AI scheduling, and client communications under a single white-label portal. Zero administrative overhead.',
    cta: 'ACCESS THE SUITE',
    href: '/solutions/crm-system',
  },
};

const cta = CTA_MAP[activePost.targetProductSku] || CTA_MAP.ai_business_tools_suite;
const encodedTitle = encodeURIComponent(
  activePost.title +
    ' ' +
    (activePost.targetProductSku === 'esim_data_plans'
      ? 'global connectivity'
      : 'business technology'),
);
const fallbackSeed = activePost.title.length;
const heroImageUrl =
  activePost.originalImage && activePost.originalImage.trim() !== ''
    ? activePost.originalImage
    : `https://image.pollinations.ai/prompt/${encodedTitle}?width=1200&height=630&nologo=true&seed=${fallbackSeed}`;

// Extract H2/H3 for Table of Contents
const tocMatches = [...mainContent.matchAll(/<h([23])[^>]*>([^<]+)<\/h[23]>/gi)];
const toc = tocMatches.map((m, i) => ({
  level: Number.parseInt(m[1]),
  text: m[2].trim(),
  id: `section-${i}`,
}));

const pillarLabels: Record<string, string> = {
  esim_data_plans: 'CONNECTIVITY',
  reputation_management: 'SEARCH AUTHORITY',
  ai_business_tools_suite: 'AI TOOLS',
};

const metaDesc = aiMeta.metaDesc || activePost.metaDesc || activePost.title;

// Short URL Generation
const shareUrl = await getOrCreateShortUrl(Astro.url.href, Astro.url.origin);
const sourceUrlShort = activePost.sourceUrl
  ? await getOrCreateShortUrl(activePost.sourceUrl, Astro.url.origin)
  : null;
const embedIframeSrc = await getOrCreateShortUrl(`${Astro.url.href}?embed=true`, Astro.url.origin);

// Breadcrumb Schema
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: Astro.site ? Astro.site.origin : 'https://bizkitgrow.vercel.app/',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Resources & Insights',
      item: Astro.site
        ? new URL('/blog', Astro.site).toString()
        : 'https://bizkitgrow.vercel.app/blog',
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: activePost.title,
      item: Astro.url.href,
    },
  ],
};

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: activePost.title,
  description: metaDesc,
  image: heroImageUrl,
  url: Astro.url.href,
  datePublished: activePost.createdAt,
  dateModified: activePost.createdAt,
  keywords: [
    ...(aiMeta.tags || []),
    pillarLabels[activePost.targetProductSku] || 'B2B',
    'Bizkitgrow',
  ].join(', '),
  author: {
    '@type': 'Organization',
    name: 'Bizkitgrow',
    url: Astro.site ? Astro.site.origin : 'https://bizkitgrow.vercel.app',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Bizkitgrow',
    url: Astro.site ? Astro.site.origin : 'https://bizkitgrow.vercel.app',
  },
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['.aeo-speakable-title', '.aeo-speakable-summary'],
  },
};
---

<BaseLayout
  title={activePost.title}
  description={metaDesc.slice(0, 155)}
  canonicalUrl={Astro.url.href}
  schemaType="Article"
  ogImage={heroImageUrl}
>
  <script type="application/ld+json" slot="schema" is:inline set:html={JSON.stringify([breadcrumbSchema, articleSchema])} />

  <!-- Reading Progress Bar -->
  <div class="fixed top-0 left-0 w-full h-[2px] bg-canvas_accent z-[100]">
    <div id="reading-progress" class="h-full bg-brand_cta w-0 transition-none"></div>
  </div>

  <main class="max-w-screen-xl mx-auto px-4 py-16">
    <div class={`flex gap-16 ${toc.length === 0 ? 'justify-center' : ''}`}>

      <!-- ═══════ SIDEBAR: Table of Contents ═══════ -->
      {toc.length > 0 && (
        <aside class="hidden xl:block w-64 shrink-0">
          <div class="sticky top-24">
            <h4 class="font-mono text-xs uppercase tracking-widest text-text_secondary mb-4 font-bold">CONTENTS</h4>
            <nav aria-label="Table of contents">
              <ul class="space-y-3">
                {toc.map((item) => (
                  <li style={`padding-left: ${(item.level - 2) * 16}px`}>
                    <a
                       href={`#${item.id}`}
                       class="font-mono text-[11px] text-text_secondary hover:text-brand_cta transition-colors leading-relaxed block"
                    >
                      {item.text.slice(0, 50)}{item.text.length > 50 ? '...' : ''}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          </div>
        </aside>
      )}

      <!-- ═══════ MAIN ARTICLE ═══════ -->
      <article class="flex-1 min-w-0 max-w-3xl" itemscope itemtype="https://schema.org/Article" aria-labelledby="post-title">
        
        <!-- Header -->
        <header class="mb-10 border-b border-borders_subtle pb-8">
          <div class="flex flex-wrap items-center gap-3 mb-5 font-mono text-xs uppercase tracking-widest text-text_secondary font-bold">
            <a href="/blog" class="hover:text-brand_cta transition-colors">RESOURCES</a>
            <span class="text-borders_subtle">/</span>
            <span class="text-brand_cta">{pillarLabels[activePost.targetProductSku] || 'RESOURCE'}</span>
          </div>

          <h1 id="post-title" itemprop="headline" class="aeo-speakable-title font-heading text-4xl sm:text-5xl md:text-6xl font-extrabold text-text_primary uppercase tracking-tight leading-[0.9] mb-6">
            {activePost.title}
          </h1>

          {aiMeta.hook ? (
            <p class="aeo-speakable-summary text-xl text-text_secondary leading-relaxed mb-6 font-medium italic border-l-4 border-brand_cta pl-4" itemprop="description">
              {aiMeta.hook}
            </p>
          ) : (metaDesc && (
            <p class="aeo-speakable-summary text-xl text-text_secondary leading-relaxed mb-6 font-medium" itemprop="description">
              {metaDesc}
            </p>
          ))}

           <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div class="flex items-center gap-4 font-mono text-xs text-text_secondary uppercase tracking-widest font-bold">
              <span>{readingTime} MIN READ</span>
              <span class="text-borders_subtle">|</span>
              <time datetime={activePost.createdAt} itemprop="datePublished">
                {activePost.createdAt
                  ? new Date(activePost.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }).toUpperCase()
                  : 'JUL 4, 2026'}
              </time>
            </div>
 
            <!-- Social Share -->
            <div class="flex items-center gap-3" role="group" aria-label="Share this article">
              <span class="font-mono text-xs text-text_secondary uppercase font-bold tracking-widest">SHARE:</span>
              <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(activePost.title)}&url=${encodeURIComponent(shareUrl)}`} target="_blank" rel="noopener noreferrer" aria-label="Share on X (Twitter)" class="w-8 h-8 flex items-center justify-center border border-borders_subtle text-text_secondary hover:border-brand_cta hover:text-brand_cta transition-colors bg-canvas_accent rounded-sm">
                <svg class="w-3 h-3" aria-hidden="true" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              </a>
              <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(shareUrl)}`} target="_blank" rel="noopener noreferrer" aria-label="Share on LinkedIn" class="w-8 h-8 flex items-center justify-center border border-borders_subtle text-text_secondary hover:border-brand_cta hover:text-brand_cta transition-colors bg-canvas_accent rounded-sm">
                <svg class="w-3 h-3" aria-hidden="true" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              </a>
            </div>
          </div>
        </header>

        <!-- Hero Image -->
        <div class="mb-10 border border-borders_subtle overflow-hidden aspect-[16/9] rounded-sm shadow-subtle bg-canvas_accent">
          <Image
            src={heroImageUrl}
            alt={activePost.title}
            class="w-full h-full object-cover"
            loading="eager"
            fetchpriority="high"
            width={1200}
            height={630}
            inferSize={!heroImageUrl.startsWith('http')}
          />
        </div>
 
        <!-- OneSignal Subscribe CTA -->
        <div class="mb-10 p-5 border border-borders_subtle flex items-center gap-4 bg-canvas_accent rounded-sm shadow-subtle hover:border-brand_cta transition-colors">
          <div class="w-8 h-8 bg-teal-50 flex items-center justify-center shrink-0 border border-brand_cta/20 rounded-sm">
            <span class="w-2 h-2 rounded-full bg-brand_cta animate-pulse"></span>
          </div>
          <div class="flex-1 min-w-0">
            <p class="font-mono text-xs text-text_primary uppercase tracking-widest font-bold">
              Get real-time resource drops. No newsletters. Only signal.
            </p>
          </div>
          <button id="subscribe-push-btn" class="font-mono text-[10px] uppercase tracking-widest bg-brand_cta text-white px-4 py-2 hover:bg-brand_cta_hover transition-colors shrink-0 font-bold rounded-sm">
            SUBSCRIBE
          </button>
        </div>
        <!-- Mobile Table of Contents (collapsible, xl:hidden) -->
        {toc.length > 0 && (
          <details class="xl:hidden mb-8 border-2 border-black bg-canvas_accent p-4 rounded-sm shadow-subtle group">
            <summary class="font-mono text-xs uppercase tracking-widest font-black cursor-pointer list-none flex items-center justify-between select-none">
              <span>TABLE OF CONTENTS</span>
              <span class="group-open:rotate-180 transition-transform font-bold">&darr;</span>
            </summary>
            <nav class="mt-4" aria-label="Table of contents mobile">
              <ul class="space-y-2">
                {toc.map((item) => (
                  <li style={`padding-left: ${(item.level - 2) * 12}px`}>
                    <a
                       href={`#${item.id}`}
                       class="font-mono text-[11px] text-text_secondary hover:text-brand_cta transition-colors leading-relaxed block py-1 border-b border-black/5"
                    >
                      {item.text}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          </details>
        )}

        <!-- Content -->
        <div class="format format-invert lg:format-lg max-w-none prose-brutalist" itemprop="articleBody" set:html={mainContent} />

        
        {aiMeta.paraphrasedHook && (
          <AGCParaphraser 
            originalText={mainContent.replace(/<[^>]*>/g, '')}
            paraphrasedHook={aiMeta.paraphrasedHook}
            syntacticVariant={aiMeta.syntacticVariant}
            paraphraseSummary={aiMeta.paraphraseSummary}
          />
        )}

        <ResellPortalWidget 
          productSku={activePost.targetProductSku}
          resellportalStatus={activePost.resellportalStatus}
          theme="light"
        />

        <!-- Source Credit -->
        {activePost.sourceUrl && (
          <div class="mt-12 p-6 border-l-4 border-brand_cta bg-canvas_accent rounded-r-sm">
             <p class="font-mono text-xs uppercase tracking-widest text-text_secondary font-bold mb-2">SOURCE MATERIAL &amp; ATTRIBUTION</p>
             <p class="text-sm text-text_secondary">
               This resource integrates external context sourced from: 
               <a href={sourceUrlShort} target="_blank" rel="noopener noreferrer" class="text-brand_cta hover:underline break-all">{sourceUrlShort}</a>
             </p>
          </div>
        )}

        <!-- Embed Briefing Widget -->
        <div class="mt-8 p-6 border border-borders_subtle bg-canvas_accent rounded-sm shadow-subtle hover:border-brand_cta transition-colors">
          <p class="font-mono text-xs uppercase tracking-widest text-text_primary font-bold mb-3">EMBED RESOURCE</p>
          <p class="text-xs text-text_secondary mb-4">
            Integrate this resource directly into your corporate dashboard or portal.
          </p>
          <div class="flex gap-2">
            <input 
              type="text" 
              readonly 
              value={`<iframe src="${embedIframeSrc}" width="100%" height="600" style="border:1px solid #E2E8F0; border-radius:0px;"></iframe>`}
              class="w-full bg-white border border-borders_subtle px-3 py-2 text-xs font-mono text-text_primary rounded-sm focus:outline-none"
              id="embed-code-input"
            />
            <button 
              id="copy-embed-btn"
              class="font-mono text-[10px] uppercase tracking-widest bg-brand_cta text-white px-4 py-2 hover:bg-brand_cta_hover transition-colors font-bold rounded-sm shrink-0"
            >
              COPY CODE
            </button>
          </div>
        </div>

        <script>
          const copyBtn = document.getElementById('copy-embed-btn');
          const input = document.getElementById('embed-code-input') as HTMLInputElement;
          if (copyBtn && input) {
            copyBtn.addEventListener('click', () => {
              input.select();
              navigator.clipboard.writeText(input.value);
              copyBtn.textContent = 'COPIED';
              setTimeout(() => {
                copyBtn.textContent = 'COPY CODE';
              }, 2000);
            });
          }
        </script>

        <!-- Social Media Copy Widget -->
        <div class="mt-8 p-6 border border-borders_subtle bg-canvas_accent rounded-sm shadow-subtle hover:border-brand_cta transition-colors">
          <p class="font-mono text-xs uppercase tracking-widest text-text_primary font-bold mb-3">SOCIAL MEDIA ASSET</p>
          <p class="text-xs text-text_secondary mb-4">
            Copy this pre-formatted resource for your social channels.
          </p>
          <div class="flex flex-col gap-3">
            <textarea 
              readonly 
              class="w-full bg-white border border-borders_subtle px-3 py-3 text-xs font-mono text-text_primary rounded-sm focus:outline-none resize-y min-h-[80px]"
              id="social-copy-textarea"
            >{`[ RESOURCE BRIEFING // ${systemArchitecture.tenant_settings.brand_name.toUpperCase()} ]\n\n${activePost.title}\n\n${metaDesc}\n\nAccess briefing: ${shareUrl}`}</textarea>
            <button 
              id="copy-social-btn"
              class="font-mono text-[10px] uppercase tracking-widest bg-brand_cta text-white px-4 py-2 hover:bg-brand_cta_hover transition-colors font-bold rounded-sm self-start"
            >
              COPY STATUS
            </button>
          </div>
        </div>

        <script>
          const copySocialBtn = document.getElementById('copy-social-btn');
          const socialInput = document.getElementById('social-copy-textarea') as HTMLTextAreaElement;
          if (copySocialBtn && socialInput) {
            copySocialBtn.addEventListener('click', () => {
              socialInput.select();
              navigator.clipboard.writeText(socialInput.value);
              copySocialBtn.textContent = 'COPIED';
              setTimeout(() => {
                copySocialBtn.textContent = 'COPY STATUS';
              }, 2000);
            });
          }
        </script>
 
        {aiMeta.tags && Array.isArray(aiMeta.tags) && aiMeta.tags.length > 0 && (
          <div class="mt-8 flex flex-wrap gap-2">
            <span class="font-mono text-[10px] text-text_secondary uppercase tracking-widest font-bold self-center mr-2">TAGS:</span>
            {aiMeta.tags.map((tag: string) => (
              <span class="bg-canvas_accent text-text_secondary text-[10px] font-mono font-bold uppercase tracking-widest px-3 py-1 rounded-sm border border-borders_subtle">{tag}</span>
            ))}
          </div>
        )}

        <!-- Prev/Next Navigation -->
        {relatedPosts.length >= 2 && (
          <div class="mt-12 flex flex-col sm:flex-row gap-4 justify-between border-t border-borders_subtle pt-8">
            <a href={`/blog/${relatedPosts[0].slug}`} class="flex-1 p-4 border border-borders_subtle hover:border-brand_cta transition-colors bg-canvas_accent group rounded-sm text-left">
              <span class="block font-mono text-[10px] text-text_secondary uppercase tracking-widest mb-1 group-hover:text-brand_cta">← PREVIOUS</span>
              <span class="block font-heading text-sm font-black text-text_primary uppercase line-clamp-2">{relatedPosts[0].title}</span>
            </a>
            <a href={`/blog/${relatedPosts[1].slug}`} class="flex-1 p-4 border border-borders_subtle hover:border-brand_cta transition-colors bg-canvas_accent group rounded-sm text-right">
              <span class="block font-mono text-[10px] text-text_secondary uppercase tracking-widest mb-1 group-hover:text-brand_cta">NEXT →</span>
              <span class="block font-heading text-sm font-black text-text_primary uppercase line-clamp-2">{relatedPosts[1].title}</span>
            </a>
          </div>
        )}

        <!-- Pillar CTA Banner -->
        <div class="mt-16 border border-gray-800 hover:border-brand_cta transition-colors p-8 flex flex-col md:flex-row items-start md:items-center justify-between gap-6 bg-black rounded-sm shadow-md">
          <div class="max-w-lg">
            <div class="font-mono text-[10px] text-gray-500 uppercase tracking-widest mb-2 font-bold">RELATED SOLUTION</div>
            <h3 class="font-heading text-2xl font-black text-white uppercase tracking-tight mb-2">{cta.headline}</h3>
            <p class="text-sm text-gray-400 leading-relaxed">{cta.body}</p>
          </div>
          <a href={cta.href} class="font-mono text-xs font-bold uppercase tracking-widest bg-brand_cta hover:bg-brand_cta_hover text-black px-6 py-3 transition-colors shrink-0 inline-flex items-center gap-2 rounded-sm shadow-sm">
            {cta.cta} <span aria-hidden="true">→</span>
          </a>
        </div>

        <!-- Related Briefings -->
        {relatedPosts.length > 0 && (
          <div class="mt-16 pt-12 border-t border-borders_subtle">
            <div class="font-mono text-xs text-text_secondary uppercase tracking-widest mb-6 font-bold">RELATED RESOURCES</div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
              {relatedPosts.map((rPost) => (
                <article class="p-6 bg-canvas_accent border border-borders_subtle hover:border-brand_cta transition-colors rounded-sm group relative">
                  <div class="font-mono text-[10px] text-text_secondary uppercase tracking-widest mb-3 font-bold">
                    {pillarLabels[rPost.targetProductSku] || 'INTELLIGENCE'}
                  </div>
                  <h4 class="font-heading text-lg font-black text-text_primary uppercase tracking-tight leading-snug mb-3 group-hover:text-brand_cta transition-colors">
                    <a href={`/blog/${rPost.slug}`} class="stretched-link line-clamp-2">{rPost.title}</a>
                  </h4>
                  <p class="font-mono text-[10px] text-text_secondary uppercase tracking-widest font-bold">
                    {rPost.createdAt
                      ? new Date(rPost.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }).toUpperCase()
                      : 'RECENT'}
                  </p>
                </article>
              ))}
            </div>
          </div>
        )}

      </article>
    </div>
  </main>

  <style is:global>
    /* Brutalist prose overrides for Flowbite format */
    .prose-brutalist {
        font-family: 'Plus Jakarta Sans', sans-serif;
    }
    .prose-brutalist h2, .prose-brutalist h3, .prose-brutalist h4 {
        font-family: 'Plus Jakarta Sans', sans-serif;
        text-transform: uppercase;
        font-weight: 800;
        letter-spacing: -0.01em;
        color: #0f172a;
    }
    .prose-brutalist h2 { font-size: 1.75rem; margin-top: 3rem; margin-bottom: 1.25rem; border-top: 1px solid #e2e8f0; padding-top: 1.5rem; }
    .prose-brutalist h3 { font-size: 1.25rem; margin-top: 2rem; margin-bottom: 1rem; color: #475569; }
    .prose-brutalist a { color: #0d9488; text-decoration: none; border-bottom: 1px solid rgba(13, 148, 136, 0.4); font-weight: 600; }
    .prose-brutalist a:hover { color: #0f766e; border-bottom-color: #0f766e; }
    .prose-brutalist a.bg-brand_cta { color: white !important; border: none !important; }
    .prose-brutalist blockquote { border-left: 4px solid #0d9488; background-color: #f8fafc; padding: 1rem 1.5rem; color: #475569; font-style: italic; font-weight: 500; }
    .prose-brutalist img { border: 1px solid #e2e8f0; border-radius: 2px; }
    .prose-brutalist code { font-family: 'JetBrains Mono', monospace; font-size: 0.85em; background-color: #f8fafc; color: #0d9488; padding: 0.2rem 0.4rem; border: 1px solid #e2e8f0; border-radius: 2px; }
    .prose-brutalist pre { background-color: #f8fafc; border: 1px solid #e2e8f0; padding: 1.25rem; border-radius: 2px; }
    .prose-brutalist pre code { border: none; padding: 0; background-color: transparent; color: inherit; }
    .stretched-link::after { position: absolute; inset: 0; z-index: 1; content: ''; }
  </style>

  <script is:inline>
    // Reading progress
    window.addEventListener('scroll', function() {
      var winScroll = document.documentElement.scrollTop;
      var height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      var progress = height > 0 ? (winScroll / height) * 100 : 0;
      var bar = document.getElementById('reading-progress');
      if (bar) bar.style.width = progress + '%';
    }, { passive: true });

    // OneSignal subscribe button
    document.getElementById('subscribe-push-btn')?.addEventListener('click', function() {
      if (window.OneSignalDeferred) {
        window.OneSignalDeferred.push(function(OneSignal) {
          OneSignal.Slidedown.promptPush();
        });
      }
    });
    
    // Automatically assign IDs to h2/h3 for TOC to work
    document.querySelectorAll('.prose-brutalist h2, .prose-brutalist h3').forEach(function(heading, index) {
       if (!heading.id) heading.id = 'section-' + index;
    });
  </script>
</BaseLayout>
