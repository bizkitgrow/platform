---
import { and, eq, ne } from 'drizzle-orm';
import { db } from '../../db/client';
import { mediaAssets, posts as postsTable } from '../../db/schema';
import BaseLayout from '../../layouts/BaseLayout.astro';

// Set public edge cache
Astro.response.headers.set('Cache-Control', 'public, max-age=0, s-maxage=3600');

export const prerender = false;

const { slug } = Astro.params;

let post: any = null;
let media: any = null;
let relatedPosts: any[] = [];

try {
  const fetchedPosts = await db
    .select()
    .from(postsTable)
    .where(eq(postsTable.slug, slug || ''))
    .limit(1);

  if (fetchedPosts.length > 0) {
    post = fetchedPosts[0];
    const fetchedMedia = await db.select().from(mediaAssets).where(eq(mediaAssets.postId, post.id)).limit(1);
    if (fetchedMedia.length > 0) media = fetchedMedia[0];

    relatedPosts = await db
      .select()
      .from(postsTable)
      .where(and(eq(postsTable.targetProductKey, post.targetProductKey || 'ai_business_tools_suite'), ne(postsTable.id, post.id)))
      .limit(2);
  }
} catch (err: any) {
  console.error('DB query failed:', err.message);
}

if (relatedPosts.length < 2) {
  try {
    const skipId = post ? post.id : -1;
    const extra = await db.select().from(postsTable).where(ne(postsTable.id, skipId)).limit(2 - relatedPosts.length);
    relatedPosts = [...relatedPosts, ...extra];
  } catch {}
}

const fallbackPost = {
  title: 'The Future of Connectivity and Mobility',
  content: '<h2>Embracing the Era of Advanced Mobility</h2><p>In today's fast-paced corporate environment, mobility and connectivity dictate market leadership. The integration of robust network infrastructures enables unprecedented growth and operational automation.</p>',
  targetProductKey: 'esim_data_plans',
  metaDesc: 'Enterprise eSIM infrastructure is replacing legacy SIM provisioning. Understand what B2B operators need in 2026.',
  createdAt: new Date().toISOString(),
};

const activePost = post || fallbackPost;
const wordCount = (activePost.polishedContent || activePost.content || '').replace(/<[^>]*>/g, '').split(/\s+/).length;
const readingTime = Math.max(2, Math.ceil(wordCount / 200));

// Dynamic CTA per pillar
const CTA_MAP: Record<string, { headline: string; body: string; cta: string; href: string }> = {
  esim_data_plans: {
    headline: 'Deploy Sovereign Connectivity',
    body: 'Instant global eSIM provisioning across 190+ countries with enterprise-grade encryption. Sub-420ms activation, zero contracts.',
    cta: 'CONFIGURE YOUR ESIM',
    href: '/esim/united-states',
  },
  reputation_management: {
    headline: 'Own the Local Search Grid',
    body: "Automate Google Business Profile optimization and review capture sequences. Dominate high-value zip codes without volatile ad spend.",
    cta: 'ACTIVATE REPUTATION ENGINE',
    href: '/reputation/new-york',
  },
  ai_business_tools_suite: {
    headline: 'Initialize Agency Automation',
    body: 'Consolidate invoicing, AI scheduling, and client communications under a single white-label portal. Zero administrative overhead.',
    cta: 'ACCESS THE SUITE',
    href: '/solutions/crm-system',
  },
};

const cta = CTA_MAP[activePost.targetProductKey] || CTA_MAP.ai_business_tools_suite;
const heroImageUrl = media
  ? media.pollinationsUrl
  : `https://image.pollinations.ai/prompt/${encodeURIComponent(activePost.imagePrompt || activePost.title + ', brutalist dark tech, neon accents')}?width=1200&height=630&nologo=true`;

// Extract H2/H3 for Table of Contents
const tocMatches = [...(activePost.polishedContent || activePost.content || '').matchAll(/<h([23])[^>]*>([^<]+)<\/h[23]>/gi)];
const toc = tocMatches.map((m, i) => ({
  level: parseInt(m[1]),
  text: m[2].trim(),
  id: `section-${i}`,
}));

const pillarLabels: Record<string, string> = {
  esim_data_plans: 'CONNECTIVITY',
  reputation_management: 'SEARCH AUTHORITY',
  ai_business_tools_suite: 'AI TOOLS',
};

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: activePost.title,
  description: activePost.metaDesc || activePost.title,
  url: Astro.url.href,
  datePublished: activePost.createdAt,
  dateModified: activePost.createdAt,
  keywords: pillarLabels[activePost.targetProductKey] || 'B2B, Technology',
  publisher: {
    '@type': 'Organization',
    name: 'Bizkitgrow',
    url: 'https://bizkitgrow.vercel.app',
  },
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['h1', 'h2', '.article-summary'],
  },
};
---

<BaseLayout
  title={activePost.title}
  description={activePost.metaDesc || activePost.content?.replace(/<[^>]*>/g, '').slice(0, 155) || activePost.title}
  canonicalUrl={Astro.url.href}
  schemaType="Article"
>
  <script type="application/ld+json" slot="schema" is:inline set:html={JSON.stringify(articleSchema)} />

  <!-- Reading Progress Bar -->
  <div class="fixed top-0 left-0 w-full h-[2px] bg-[#1c1c1e] z-50">
    <div id="reading-progress" class="h-full bg-[#00ff66] w-0 transition-none"></div>
  </div>

  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="flex gap-16">

      <!-- ═══════ SIDEBAR: Table of Contents ═══════ -->
      {toc.length > 2 && (
        <aside class="hidden xl:block w-52 shrink-0">
          <div class="sticky top-24">
            <div class="font-['JetBrains_Mono'] text-[9px] uppercase tracking-widest text-[#52525b] mb-3">CONTENTS</div>
            <nav aria-label="Table of contents">
              <ul class="space-y-2">
                {toc.map((item) => (
                  <li style={`padding-left: ${(item.level - 2) * 12}px`}>
                    <a
                      href={`#${item.id}`}
                      class="font-['JetBrains_Mono'] text-[10px] text-[#52525b] hover:text-[#00ff66] transition-colors leading-relaxed block"
                    >
                      {item.text.slice(0, 40)}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          </div>
        </aside>
      )}

      <!-- ═══════ MAIN ARTICLE ═══════ -->
      <article class="flex-1 min-w-0 max-w-3xl" itemscope itemtype="https://schema.org/Article">

        <!-- Article Header -->
        <header class="mb-10 border-b border-[#1c1c1e] pb-8">
          <div class="flex flex-wrap items-center gap-3 mb-5 font-['JetBrains_Mono'] text-[9px] uppercase tracking-widest text-[#52525b]">
            <a href="/blog" class="hover:text-[#71717a] transition-colors">INTELLIGENCE</a>
            <span class="text-[#1c1c1e]">/</span>
            <span class="text-[#00ff66]">{pillarLabels[activePost.targetProductKey] || 'BRIEFING'}</span>
          </div>

          <h1
            itemprop="headline"
            class="font-['Outfit'] text-4xl sm:text-5xl md:text-6xl font-black text-white uppercase tracking-tight leading-[0.9] mb-6"
          >
            {activePost.title}
          </h1>

          {activePost.metaDesc && (
            <p class="article-summary text-base text-[#71717a] leading-relaxed mb-6 max-w-2xl" itemprop="description">
              {activePost.metaDesc}
            </p>
          )}

          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div class="flex items-center gap-4 font-['JetBrains_Mono'] text-[9px] text-[#52525b] uppercase tracking-wider">
              <span>{readingTime} MIN READ</span>
              <span class="text-[#1c1c1e]">|</span>
              <time datetime={activePost.createdAt} itemprop="datePublished">
                {activePost.createdAt
                  ? new Date(activePost.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }).toUpperCase()
                  : 'JUL 4, 2026'}
              </time>
            </div>

            <!-- Social Share -->
            <div class="flex items-center gap-3" role="group" aria-label="Share this article">
              <span class="font-['JetBrains_Mono'] text-[9px] text-[#52525b] uppercase">SHARE:</span>
              <a
                href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(activePost.title)}&url=${encodeURIComponent(Astro.url.href)}`}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Share on X (Twitter)"
                class="w-7 h-7 flex items-center justify-center border border-[#1c1c1e] text-[#52525b] hover:border-white hover:text-white transition-colors"
              >
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              </a>
              <a
                href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(Astro.url.href)}`}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Share on LinkedIn"
                class="w-7 h-7 flex items-center justify-center border border-[#1c1c1e] text-[#52525b] hover:border-white hover:text-white transition-colors"
              >
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              </a>
            </div>
          </div>
        </header>

        <!-- Hero Image -->
        <div class="mb-10 border border-[#1c1c1e] overflow-hidden aspect-[16/9]">
          <img
            src={heroImageUrl}
            alt={activePost.title}
            class="w-full h-full object-cover"
            loading="eager"
            fetchpriority="high"
            width="1200"
            height="630"
          />
        </div>

        <!-- OneSignal Subscribe CTA (inline, post intro) -->
        <div class="mb-10 p-5 border border-[#1c1c1e] flex items-center gap-4 bg-[#0a0a0a]">
          <div class="w-8 h-8 bg-[#00ff66]/10 flex items-center justify-center shrink-0">
            <span class="w-2 h-2 rounded-full bg-[#00ff66] animate-pulse"></span>
          </div>
          <div class="flex-1 min-w-0">
            <p class="font-['JetBrains_Mono'] text-[10px] text-[#71717a] uppercase tracking-widest">
              Get real-time intelligence drops. No newsletters. Only signal.
            </p>
          </div>
          <button
            id="subscribe-push-btn"
            class="font-['JetBrains_Mono'] text-[9px] uppercase tracking-widest bg-[#00ff66] text-black px-4 py-2 hover:bg-[#00e65c] transition-colors shrink-0 font-bold"
          >
            SUBSCRIBE
          </button>
        </div>

        <!-- Article Content -->
        <div
          class="prose-article"
          itemprop="articleBody"
          set:html={activePost.polishedContent || activePost.content}
        />

        <!-- Pillar CTA Banner -->
        <div class="mt-16 border border-[#1c1c1e] hover:border-[#3f3f46] transition-colors p-8 flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
          <div class="max-w-lg">
            <div class="font-['JetBrains_Mono'] text-[9px] text-[#52525b] uppercase tracking-widest mb-2">RELATED SOLUTION</div>
            <h3 class="font-['Outfit'] text-2xl font-black text-white uppercase tracking-tight mb-2">{cta.headline}</h3>
            <p class="text-sm text-[#71717a] leading-relaxed">{cta.body}</p>
          </div>
          <a
            href={cta.href}
            class="font-['JetBrains_Mono'] text-[10px] font-bold uppercase tracking-widest bg-[#ff4500] hover:bg-[#ff5714] text-white px-6 py-3 transition-colors shrink-0 inline-flex items-center gap-2"
          >
            {cta.cta} <span aria-hidden="true">→</span>
          </a>
        </div>

        <!-- Related Briefings -->
        {relatedPosts.length > 0 && (
          <div class="mt-16 pt-12 border-t border-[#1c1c1e]">
            <div class="font-['JetBrains_Mono'] text-[10px] text-[#52525b] uppercase tracking-widest mb-6">RELATED BRIEFINGS</div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-0 divide-y sm:divide-y-0 sm:divide-x divide-[#1c1c1e]">
              {relatedPosts.map((rPost) => (
                <article class="py-6 sm:px-6 first:pl-0 last:pr-0 group">
                  <div class="font-['JetBrains_Mono'] text-[9px] text-[#52525b] uppercase tracking-widest mb-2">
                    {pillarLabels[rPost.targetProductKey] || 'INTELLIGENCE'}
                  </div>
                  <h4 class="font-['Outfit'] text-lg font-black text-white uppercase tracking-tight leading-snug mb-2 group-hover:text-[#a1a1aa] transition-colors">
                    <a href={`/blog/${rPost.slug}`} class="stretched-link line-clamp-2">{rPost.title}</a>
                  </h4>
                  <p class="font-['JetBrains_Mono'] text-[9px] text-[#3f3f46] uppercase tracking-wider">
                    {rPost.createdAt
                      ? new Date(rPost.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }).toUpperCase()
                      : 'RECENT'}
                  </p>
                </article>
              ))}
            </div>
          </div>
        )}

      </article>
    </div>
  </div>

  <style is:global>
    /* Article prose styles (dark premium) */
    .prose-article { color: #a1a1aa; line-height: 1.75; font-family: 'Plus Jakarta Sans', sans-serif; }
    .prose-article h2 { font-family: 'Outfit', sans-serif; font-size: 1.5rem; font-weight: 900; color: #f4f4f5; text-transform: uppercase; letter-spacing: -0.025em; margin-top: 2.5rem; margin-bottom: 1rem; padding-top: 1rem; border-top: 1px solid #1c1c1e; }
    .prose-article h3 { font-family: 'Outfit', sans-serif; font-size: 1.25rem; font-weight: 800; color: #e4e4e7; text-transform: uppercase; letter-spacing: -0.02em; margin-top: 2rem; margin-bottom: 0.75rem; }
    .prose-article p { margin-bottom: 1.25rem; }
    .prose-article strong { color: #f4f4f5; font-weight: 600; }
    .prose-article a { color: #00ff66; text-decoration: none; border-bottom: 1px solid #00ff6640; }
    .prose-article a:hover { color: #fff; border-bottom-color: #fff; }
    .prose-article ul, .prose-article ol { margin: 1.25rem 0; padding-left: 1.5rem; }
    .prose-article li { margin-bottom: 0.5rem; }
    .prose-article blockquote { border-left: 2px solid #00ff66; padding-left: 1.25rem; color: #71717a; font-style: italic; margin: 2rem 0; }
    .prose-article code { font-family: 'JetBrains Mono', monospace; font-size: 0.8em; background: #0a0a0a; border: 1px solid #1c1c1e; padding: 0.15em 0.4em; color: #00ff66; }
    .prose-article pre { background: #0a0a0a; border: 1px solid #1c1c1e; padding: 1.25rem; overflow-x: auto; margin: 1.5rem 0; }
    .prose-article pre code { background: none; border: none; padding: 0; }
    .stretched-link::after { position: absolute; inset: 0; z-index: 1; content: ''; }
    article { position: relative; }
  </style>

  <script is:inline>
    // Reading progress
    window.addEventListener('scroll', function() {
      var winScroll = document.documentElement.scrollTop;
      var height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      var progress = height > 0 ? (winScroll / height) * 100 : 0;
      var bar = document.getElementById('reading-progress');
      if (bar) bar.style.width = progress + '%';
    }, { passive: true });

    // OneSignal subscribe button
    document.getElementById('subscribe-push-btn')?.addEventListener('click', function() {
      if (window.OneSignalDeferred) {
        window.OneSignalDeferred.push(function(OneSignal) {
          OneSignal.Slidedown.promptPush();
        });
      }
    });
  </script>
</BaseLayout>
