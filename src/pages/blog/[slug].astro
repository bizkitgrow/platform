---
import { and, eq, ne } from 'drizzle-orm';
import { db } from '../../db/client';
import { mediaAssets, posts as postsTable } from '../../db/schema';
import BaseLayout from '../../layouts/BaseLayout.astro';

// Set public edge cache control for high-speed delivery
Astro.response.headers.set('Cache-Control', 'public, max-age=0, s-maxage=3600');

export const prerender = false; // Using SSR/ISR (Astro hybrid mode)

const { slug } = Astro.params;

let post: any = null;
let media: any = null;
let relatedPosts: any[] = [];

try {
  const fetchedPosts = await db
    .select()
    .from(postsTable)
    .where(eq(postsTable.slug, slug || ''))
    .limit(1);
  if (fetchedPosts.length > 0) {
    post = fetchedPosts[0];
    const fetchedMedia = await db
      .select()
      .from(mediaAssets)
      .where(eq(mediaAssets.postId, post.id))
      .limit(1);
    if (fetchedMedia.length > 0) {
      media = fetchedMedia[0];
    }

    // Query related posts
    relatedPosts = await db
      .select()
      .from(postsTable)
      .where(
        and(
          eq(postsTable.targetProductKey, post.targetProductKey || 'esim_data_plans'),
          ne(postsTable.id, post.id),
        ),
      )
      .limit(2);
  }
} catch (err: any) {
  console.error('Failed to query post from database:', err.message);
}

if (relatedPosts.length < 2) {
  try {
    const skipId = post ? post.id : -1;
    const additional = await db
      .select()
      .from(postsTable)
      .where(ne(postsTable.id, skipId))
      .limit(2 - relatedPosts.length);
    relatedPosts = [...relatedPosts, ...additional];
  } catch (err) {
    // ignore related posts fallback errors
  }
}

const fallbackPost = {
  title: 'The Future of Connectivity and Mobility',
  content:
    "<h2>Embracing the Era of Advanced Mobility</h2><p>In today's fast-paced corporate environment, mobility and connectivity dictate market leadership. The integration of robust network infrastructures enables unprecedented growth and operational automation.</p><p>We can explore deep metrics about how latency affects bottom lines...</p>",
  target_product_key: 'esim_data_plans',
  readingTime: '3 min read',
  imagePrompt:
    'Abstract visualization of glowing fiber optic cables representing global connectivity, enterprise technology, teal and slate colors, minimalist, hyper-realistic',
};

const activePost = post
  ? {
      title: post.title,
      content: post.polishedContent || post.content,
      target_product_key: post.targetProductKey || 'esim_data_plans',
      readingTime: '3 min read',
      imagePrompt: media
        ? media.promptString
        : 'Abstract visualization of glowing fiber optic cables representing global connectivity',
    }
  : fallbackPost;

const BASE_CHECKOUT_URL = 'https://devhack.appserviceportal.com/checkout';
const checkoutUrl = `${BASE_CHECKOUT_URL}?product_id=${activePost.target_product_key}`;

const heroImageUrl = media
  ? media.pollinationsUrl
  : `https://image.pollinations.ai/prompt/${encodeURIComponent(activePost.imagePrompt)}?width=1200&height=630&nologo=true`;
---

<BaseLayout 
  title={activePost.title} 
  description={activePost.content ? activePost.content.replace(/<[^>]*>/g, '').slice(0, 150) : activePost.title}
  canonicalUrl={Astro.url.href}
>
  <!-- Reading Progress Bar -->
  <div class="fixed top-0 left-0 w-full h-1 bg-gray-100 dark:bg-gray-800 z-50">
    <div id="reading-progress" class="h-full bg-blue-600 w-0 transition-all duration-75 dark:bg-blue-500"></div>
  </div>

  <article class="max-w-3xl mx-auto px-6 py-20 dark:text-gray-100">
    
    <!-- Fuwari/Vercel Style Centered Header -->
    <header class="mb-12 border-b border-gray-150 pb-8 dark:border-gray-800">
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-black text-gray-900 tracking-tight leading-tight dark:text-white">
        {activePost.title}
      </h1>

      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mt-6">
        <div class="flex items-center gap-3 text-xs text-gray-400 font-semibold uppercase tracking-wider dark:text-gray-500">
          <span>Published Briefing</span>
          <span class="w-1.5 h-1.5 rounded-full bg-gray-300 dark:bg-gray-700"></span>
          <span>{activePost.readingTime}</span>
        </div>
        
        <!-- Social Sharing Panel (Astro Blog Kit Inspired) -->
        <div class="flex items-center gap-2">
          <span class="text-xs font-bold text-gray-400 dark:text-gray-500 uppercase mr-1">Share:</span>
          <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(activePost.title)}&url=${encodeURIComponent(Astro.url.href)}`} target="_blank" rel="noopener noreferrer" class="p-1.5 text-gray-400 hover:text-blue-500 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors" title="Share on Twitter/X">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(Astro.url.href)}`} target="_blank" rel="noopener noreferrer" class="p-1.5 text-gray-400 hover:text-blue-700 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors" title="Share on LinkedIn">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        </div>
      </div>
    </header>

    <!-- Premium Hero Image -->
    <div class="mb-12 rounded-3xl overflow-hidden shadow-sm border border-gray-200 aspect-[16/9] dark:border-gray-700">
      <img src={heroImageUrl} alt={activePost.title} class="w-full h-full object-cover" loading="eager" />
    </div>

    <!-- Minimalist Intent Bridge Banner (CTA Card) -->
    <div class="my-12 p-8 bg-gray-50 border border-gray-200 rounded-3xl dark:bg-gray-800 dark:border-gray-700 flex flex-col md:flex-row items-start md:items-center justify-between gap-6 hover:shadow-sm transition-all duration-200">
      <div class="max-w-lg">
        <h3 class="text-xl font-black text-gray-900 mb-2 dark:text-white">Upgrade Your Corporate Mobility</h3>
        <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed">Unlock seamless connectivity for your enterprise across 190+ countries with our scalable eSIM infrastructure.</p>
      </div>
      <a href={checkoutUrl} class="w-full md:w-auto text-center text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:ring-blue-300 font-bold rounded-2xl text-sm px-6 py-3 dark:bg-blue-600 dark:hover:bg-blue-700 focus:outline-none dark:focus:ring-blue-850 transition-all whitespace-nowrap">
        Deploy Now
      </a>
    </div>

    <!-- Article Content -->
    <div class="prose prose-lg prose-slate dark:prose-invert max-w-none text-gray-700 dark:text-gray-300 leading-relaxed" set:html={activePost.content} />

    <!-- Related Briefings (Astro Essentials & Pedes Inspired) -->
    {relatedPosts.length > 0 && (
      <div class="mt-16 pt-12 border-t border-gray-150 dark:border-gray-800">
        <h3 class="text-xl font-black text-gray-900 mb-6 dark:text-white">Related Briefings</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {relatedPosts.map((rPost) => (
            <a href={`/blog/${rPost.slug}`} class="block p-6 bg-white border border-gray-200 rounded-3xl hover:shadow-md hover:scale-[1.01] transition-all duration-200 dark:bg-gray-800 dark:border-gray-700">
              <span class="text-[10px] font-bold text-blue-600 uppercase tracking-widest dark:text-blue-400">{rPost.targetProductKey || 'connectivity'}</span>
              <h4 class="text-lg font-black text-gray-900 mt-2 mb-1 dark:text-white line-clamp-1">{rPost.title}</h4>
              <p class="text-xs text-gray-400 dark:text-gray-500 font-semibold">{rPost.createdAt ? new Date(rPost.createdAt).toLocaleDateString() : 'Recent'}</p>
            </a>
          ))}
        </div>
      </div>
    )}
    
  </article>

  <script is:inline>
    // Smooth reading progress tracker
    window.addEventListener('scroll', () => {
      const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
      const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      const scrolled = (winScroll / height) * 100;
      const progress = document.getElementById('reading-progress');
      if (progress) {
        progress.style.width = scrolled + '%';
      }
    });
  </script>
</BaseLayout>
