---
export const prerender = false;
import { count } from 'drizzle-orm';
import { db } from '../../db/client';
import { posts as postsTable } from '../../db/schema';
import AdminLayout from '../../layouts/AdminLayout.astro';

let postsCount = 0;
let logsCount = 0;

try {
  const [{ value: pCount }] = await db.select({ value: count() }).from(postsTable);
  postsCount = pCount;
} catch (err) {
  console.error('Failed to load admin stats', err);
}
---

<AdminLayout title="Dashboard">
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-4">
    <!-- Stat Box 1 -->
    <div class="border-2 border-dashed border-gray-300 rounded-lg dark:border-gray-600 h-32 md:h-64 flex flex-col items-center justify-center bg-white dark:bg-gray-800">
      <h3 class="text-4xl font-bold text-gray-900 dark:text-white">{postsCount}</h3>
      <p class="text-gray-500 dark:text-gray-400">Total Briefings</p>
    </div>
    <!-- Stat Box 2 -->
    <div class="border-2 border-dashed border-gray-300 rounded-lg dark:border-gray-600 h-32 md:h-64 flex flex-col items-center justify-center bg-white dark:bg-gray-800">
      <h3 class="text-4xl font-bold text-gray-900 dark:text-white">{logsCount}</h3>
      <p class="text-gray-500 dark:text-gray-400">Automation Logs</p>
    </div>
    <!-- Stat Box 3 -->
    <div class="border-2 border-dashed border-gray-300 rounded-lg dark:border-gray-600 h-32 md:h-64 flex flex-col items-center justify-center bg-white dark:bg-gray-800">
      <h3 class="text-4xl font-bold text-gray-900 dark:text-white">Active</h3>
      <p class="text-gray-500 dark:text-gray-400">Pipeline Status</p>
    </div>
    <!-- Stat Box 4 -->
    <div class="border-2 border-dashed border-gray-300 rounded-lg dark:border-gray-600 h-32 md:h-64 flex flex-col items-center justify-center bg-white dark:bg-gray-800">
      <h3 class="text-4xl font-bold text-gray-900 dark:text-white">3</h3>
      <p class="text-gray-500 dark:text-gray-400">Growth Vectors</p>
    </div>
  </div>
</AdminLayout>
