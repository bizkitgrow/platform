---
export const prerender = false;

import { count, desc } from 'drizzle-orm';
import { db } from '../../db/client';
import {
  automationLogs,
  posts as postsTable,
  rssSources,
  socialShares,
  waitingList,
} from '../../db/schema';
import BaseLayout from '../../layouts/BaseLayout.astro';

// Basic Authentication Gate for Admin Perimeter
const authHeader = Astro.request.headers.get('Authorization');
if (!authHeader || !authHeader.startsWith('Basic ')) {
  Astro.response.headers.set('WWW-Authenticate', 'Basic realm="Bizkitgrow Admin Perimeter"');
  return new Response('Unauthorized Access', { status: 401 });
}

try {
  const credentials = Buffer.from(authHeader.split(' ')[1], 'base64').toString('ascii');
  const [username, password] = credentials.split(':');

  if (username !== import.meta.env.ADMIN_USERNAME || password !== import.meta.env.ADMIN_PASSWORD) {
    Astro.response.headers.set('WWW-Authenticate', 'Basic realm="Bizkitgrow Admin Perimeter"');
    return new Response('Unauthorized Access', { status: 401 });
  }
} catch (err) {
  Astro.response.headers.set('WWW-Authenticate', 'Basic realm="Bizkitgrow Admin Perimeter"');
  return new Response('Unauthorized Access', { status: 401 });
}

const currentUrl = 'https://bizkitgrow.vercel.app/admin';

// Initialize variables with DB metrics or defaults
let totalWaitlistCount = 0;
let totalPosts = 0;
let successfulShares = 0;
const failedShares = 0;
let feeds: any[] = [];
let logs: any[] = [];

try {
  // 1. Fetch counts
  const waitlistRes = await db.select({ value: count() }).from(waitingList);
  totalWaitlistCount = waitlistRes[0]?.value || 0;

  const postsRes = await db.select({ value: count() }).from(postsTable);
  totalPosts = postsRes[0]?.value || 0;

  const successSharesRes = await db.select({ value: count() }).from(socialShares); // Mock status parsing
  successfulShares = successSharesRes[0]?.value || 0;

  // 2. Fetch feeds list
  feeds = await db.select().from(rssSources).limit(5);

  // 3. Fetch automation logs
  logs = await db.select().from(automationLogs).orderBy(desc(automationLogs.createdAt)).limit(5);
} catch (err: any) {
  console.error('Dashboard DB query error, using fallback dashboard view:', err.message);
}

// Fallback visual data if DB is unseeded/empty
const activeRssFeeds =
  feeds.length > 0
    ? feeds
    : [
        {
          url: 'https://news.ycombinator.com/rss',
          targetPillar: 'connectivity',
          isActive: true,
          lastFetchedAt: 'Seeding pending',
        },
      ];

const systemLogs =
  logs.length > 0
    ? logs.map((l) => ({
        timestamp: l.createdAt ? new Date(l.createdAt).toLocaleTimeString() : 'N/A',
        level: l.status,
        message: l.errorDetails || `Miner fetched ${l.itemsFetched} new items.`,
      }))
    : [
        {
          timestamp: '09:22:43',
          level: 'INFO',
          message: 'Master Dashboard telemetry wire initialized.',
        },
      ];
---

<BaseLayout 
  title="Operations Dashboard" 
  description="Bizkitgrow live telemetry tracker, content ingestion control, and API monitoring hub."
  canonicalUrl={currentUrl}
>
  <main class="max-w-[1280px] mx-auto px-6 py-16">
    <header class="mb-12 flex flex-col md:flex-row items-start md:items-center justify-between gap-6 border-b border-border-subtle pb-8">
      <div>
        <h1 class="text-3xl sm:text-4xl font-extrabold text-text-primary tracking-tight">Operations Dashboard</h1>
        <p class="text-text-secondary mt-1 text-sm">Bizkitgrow Platform Master Administration Console.</p>
      </div>
      <div class="flex items-center gap-3">
        <button id="trigger-pipeline-btn" class="h-10 px-5 inline-flex items-center justify-center rounded-xl bg-interactive-normal hover:bg-interactive-hover text-text-inverse text-xs font-bold shadow-sm transition-all duration-150">
          Run Aggregator
        </button>
        <button id="trigger-digest-btn" class="h-10 px-5 inline-flex items-center justify-center rounded-xl border border-border-subtle hover:border-text-primary bg-background-surface text-text-primary text-xs font-bold shadow-sm transition-all">
          Generate Daily Digest
        </button>
      </div>
    </header>

    <!-- Telemetry Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
      <div class="p-6 bg-background-surface border border-border-subtle rounded-2xl">
        <p class="text-xs font-bold text-text-secondary uppercase tracking-wider mb-2">Total Subscribers</p>
        <p class="text-3xl font-extrabold text-text-primary">{totalWaitlistCount}</p>
      </div>
      <div class="p-6 bg-background-surface border border-border-subtle rounded-2xl">
        <p class="text-xs font-bold text-text-secondary uppercase tracking-wider mb-2">Ingested Posts</p>
        <p class="text-3xl font-extrabold text-text-primary">{totalPosts}</p>
      </div>
      <div class="p-6 bg-background-surface border border-border-subtle rounded-2xl">
        <p class="text-xs font-bold text-text-secondary uppercase tracking-wider mb-2">Successful Shares</p>
        <p class="text-3xl font-extrabold text-emerald-600">{successfulShares}</p>
      </div>
      <div class="p-6 bg-background-surface border border-border-subtle rounded-2xl">
        <p class="text-xs font-bold text-text-secondary uppercase tracking-wider mb-2">System Health</p>
        <p class="text-3xl font-extrabold text-emerald-600">Secure</p>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Active RSS Feeds -->
      <section class="lg:col-span-2 bg-background-surface border border-border-subtle rounded-2xl p-6 sm:p-8">
        <h2 class="text-xl font-bold text-text-primary mb-6">Active Content Feeds</h2>
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="border-b border-border-subtle text-xs font-bold text-text-secondary uppercase">
                <th class="pb-3">Feed Source</th>
                <th class="pb-3">Target Pillar</th>
                <th class="pb-3">Status</th>
                <th class="pb-3 text-right">Last Sync</th>
              </tr>
            </thead>
            <tbody class="text-sm">
              {activeRssFeeds.map((feed) => (
                <tr class="border-b border-border-subtle/50 text-text-primary">
                  <td class="py-4 font-semibold max-w-xs truncate">{feed.url}</td>
                  <td class="py-4 text-text-secondary capitalize">{feed.targetPillar || feed.pillar}</td>
                  <td class="py-4">
                    <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full text-xs font-medium bg-emerald-100 text-emerald-800">
                      <span class="w-1.5 h-1.5 rounded-full bg-emerald-600"></span>
                      {feed.isActive ? 'ACTIVE' : 'INACTIVE'}
                    </span>
                  </td>
                  <td class="py-4 text-right text-text-secondary">{feed.lastFetchedAt ? new Date(feed.lastFetchedAt).toLocaleTimeString() : 'Never'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <!-- Hardening Check Component mapped to Hardening-Audit-Tool-AuditTAP repository concepts -->
        <div class="mt-8 pt-8 border-t border-border-subtle">
          <h3 class="text-lg font-bold text-text-primary mb-4">Hardening & Security Audit</h3>
          <div id="hardening-audit-card" class="p-5 bg-background-base border border-border-subtle rounded-xl flex items-center justify-between">
            <div>
              <p class="text-sm font-semibold text-text-primary">Supabase & API Perimeter Status</p>
              <p id="hardening-status-desc" class="text-xs text-text-secondary">Run audit checklist to check RLS and Key Sanitization.</p>
            </div>
            <button id="run-audit-btn" class="h-9 px-4 rounded-lg bg-background-surface hover:bg-border-subtle text-text-primary border border-border-subtle text-xs font-bold transition-all">
              Run Security Audit
            </button>
          </div>
        </div>
      </section>

      <!-- System Logs -->
      <section class="bg-background-surface border border-border-subtle rounded-2xl p-6 sm:p-8">
        <h2 class="text-xl font-bold text-text-primary mb-6">Live Automation Logs</h2>
        <div class="space-y-4">
          {systemLogs.map((log) => (
            <div class="text-xs border-b border-border-subtle/40 pb-3 last:border-0 last:pb-0">
              <div class="flex items-center justify-between mb-1.5">
                <span class="text-text-secondary font-mono">{log.timestamp}</span>
                <span class={`px-1.5 py-0.5 rounded text-[10px] font-bold ${
                  log.level === 'SUCCESS' ? 'bg-emerald-100 text-emerald-800' : 'bg-blue-100 text-blue-800'
                }`}>
                  {log.level}
                </span>
              </div>
              <p class="text-text-primary font-medium">{log.message}</p>
            </div>
          ))}
        </div>
      </section>
    </div>
  </main>

  <script is:inline>
    // Ingestion triggers
    const triggerBtn = document.getElementById('trigger-pipeline-btn');
    if (triggerBtn) {
      triggerBtn.addEventListener('click', async () => {
        triggerBtn.disabled = true;
        triggerBtn.textContent = 'Scraping...';
        try {
          const res = await fetch('/api/v1/social/syndicate', { method: 'POST' });
          const data = await res.json();
          if (res.ok) {
            alert('Aggregator pipeline executed successfully!');
            window.location.reload();
          } else {
            alert(`Execution failed: ${data.error}`);
          }
        } catch (err) {
          alert('Network timeout. Execution logged to system logs.');
        } finally {
          triggerBtn.disabled = false;
          triggerBtn.textContent = 'Run Aggregator';
        }
      });
    }

    // Daily digest triggers
    const digestBtn = document.getElementById('trigger-digest-btn');
    if (digestBtn) {
      digestBtn.addEventListener('click', async () => {
        digestBtn.disabled = true;
        digestBtn.textContent = 'Generating...';
        try {
          const res = await fetch('/api/v1/admin/digest', { method: 'POST' });
          const data = await res.json();
          if (res.ok && data.success) {
            alert(data.message);
            window.location.reload();
          } else {
            alert(`Digest failure: ${data.error || 'Failed'}`);
          }
        } catch (err) {
          alert('System error building daily digest.');
        } finally {
          digestBtn.disabled = false;
          digestBtn.textContent = 'Generate Daily Digest';
        }
      });
    }

    // Hardening check triggers
    const auditBtn = document.getElementById('run-audit-btn');
    const hardeningDesc = document.getElementById('hardening-status-desc');
    const hardeningCard = document.getElementById('hardening-audit-card');
    
    if (auditBtn && hardeningDesc) {
      auditBtn.addEventListener('click', async () => {
        auditBtn.disabled = true;
        hardeningDesc.textContent = 'Auditing environment parameters...';
        try {
          const res = await fetch('/api/v1/admin/audit');
          const data = await res.json();
          if (res.ok && data.success) {
            const { databaseConnection, rlsEnabled, apiTokenSecurity } = data.checks;
            const statusStr = `DB Connected: ${databaseConnection ? 'YES' : 'NO'} | RLS Secure: ${rlsEnabled ? 'YES' : 'NO'} | Key Sanitized: ${apiTokenSecurity ? 'YES' : 'NO'}`;
            hardeningDesc.textContent = statusStr;
            hardeningCard.classList.remove('bg-background-base');
            
            if (databaseConnection && rlsEnabled && apiTokenSecurity) {
              hardeningCard.classList.add('bg-emerald-50', 'border-emerald-200');
            } else {
              hardeningCard.classList.add('bg-rose-50', 'border-rose-200');
            }
          } else {
            hardeningDesc.textContent = 'Audit process failed to complete.';
          }
        } catch (err) {
          hardeningDesc.textContent = 'Hardening check failed. Connection offline.';
        } finally {
          auditBtn.disabled = false;
        }
      });
    }
  </script>
</BaseLayout>
