---
export const prerender = false;
import { count } from 'drizzle-orm';
import { db } from '../../db/client';
import { posts as postsTable } from '../../db/schema';
import AdminLayout from '../../layouts/AdminLayout.astro';

let postsCount = 0;
const logsCount = 0;

try {
  const [{ value: pCount }] = await db.select({ value: count() }).from(postsTable);
  postsCount = pCount;
} catch (err) {
  console.error('Failed to load admin stats', err);
}
---

<AdminLayout title="Dashboard & CMS">
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <div class="border-2 border-black rounded-sm h-32 md:h-48 flex flex-col items-center justify-center bg-white shadow-brutal">
      <h3 class="text-4xl font-bold text-black font-mono">{postsCount}</h3>
      <p class="text-gray-600 font-mono text-xs mt-2 uppercase">Total Briefings</p>
    </div>
    <div class="border-2 border-black rounded-sm h-32 md:h-48 flex flex-col items-center justify-center bg-white shadow-brutal">
      <h3 class="text-4xl font-bold text-black font-mono">{logsCount}</h3>
      <p class="text-gray-600 font-mono text-xs mt-2 uppercase">Automation Logs</p>
    </div>
    <div class="border-2 border-black rounded-sm h-32 md:h-48 flex flex-col items-center justify-center bg-white shadow-brutal col-span-1 sm:col-span-2 lg:col-span-2 p-6 text-center">
      <h3 class="text-xl font-bold text-black font-mono mb-2 uppercase">Terminal Tools</h3>
      <p class="text-gray-600 font-mono text-xs mb-4">Run manual ingestion from your local terminal:</p>
      <code class="bg-canvas_accent text-black p-2 border-2 border-black text-xs">node scripts/bizkit-cli.js</code>
    </div>
  </div>

  <div class="bg-white border-2 border-black shadow-brutal p-8 mb-8">
    <h2 class="text-2xl font-black uppercase font-heading border-b-2 border-black pb-4 mb-6">Create Intelligence Briefing (Manual CMS)</h2>
    <form id="cms-form" class="space-y-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block font-mono text-xs font-bold uppercase mb-2">Title</label>
          <input type="text" id="title" required class="w-full border-2 border-black p-3 bg-canvas_accent font-mono text-sm focus:outline-none focus:border-brand_cta" />
        </div>
        <div>
          <label class="block font-mono text-xs font-bold uppercase mb-2">Slug</label>
          <input type="text" id="slug" required class="w-full border-2 border-black p-3 bg-canvas_accent font-mono text-sm focus:outline-none focus:border-brand_cta" />
        </div>
      </div>
      <div>
        <label class="block font-mono text-xs font-bold uppercase mb-2">Target Product SKU / Pillar</label>
        <select id="productSku" class="w-full border-2 border-black p-3 bg-canvas_accent font-mono text-sm focus:outline-none focus:border-brand_cta">
          <option value="general">General Guide</option>
          <option value="esim_data_plans">eSIM & Global Connectivity</option>
          <option value="reputation_management">Reputation Management</option>
          <option value="ai_business_tools_suite">AI Business / CRM Suite</option>
        </select>
      </div>
      <div>
        <label class="block font-mono text-xs font-bold uppercase mb-2">Meta Description / Hook</label>
        <textarea id="metaDesc" rows="2" class="w-full border-2 border-black p-3 bg-canvas_accent font-mono text-sm focus:outline-none focus:border-brand_cta"></textarea>
      </div>
      <div>
        <label class="block font-mono text-xs font-bold uppercase mb-2">Content</label>
        <textarea id="contentHtml" rows="10" class="w-full border-2 border-black p-3 bg-canvas_accent font-mono text-sm focus:outline-none focus:border-brand_cta"></textarea>
      </div>
      <button type="submit" class="bg-brand_cta text-white border-2 border-black font-mono font-bold uppercase px-8 py-4 hover:bg-black transition-colors w-full md:w-auto">
        PUBLISH BRIEFING
      </button>
    </form>
  </div>

  <script is:inline>
    document.getElementById('cms-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const contentHtml = document.getElementById('contentHtml').value;
      if (!contentHtml || contentHtml.trim() === '' || contentHtml.trim() === '<p></p>') {
        if (window.GlobalUI) window.GlobalUI.showToast('Briefing content is required.', 'error');
        return;
      }

      if(window.GlobalUI) window.GlobalUI.showLoading();
      
      const payload = {
        action: 'manual_create',
        title: document.getElementById('title').value,
        slug: document.getElementById('slug').value,
        contentHtml: contentHtml,
        metaDesc: document.getElementById('metaDesc').value,
        productSku: document.getElementById('productSku').value,
      };

      try {
        const res = await fetch('/api/v1/admin/posts', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });
        const data = await res.json();
        
        if (res.ok) {
          if(window.GlobalUI) window.GlobalUI.showToast('Briefing published successfully!', 'success');
          e.target.reset();
        } else {
          if(window.GlobalUI) window.GlobalUI.showToast(`Error: ${data.error}`, 'error');
        }
      } catch (err) {
        if(window.GlobalUI) window.GlobalUI.showToast('Network error while publishing.', 'error');
      } finally {
        if(window.GlobalUI) window.GlobalUI.hideLoading();
      }
    });

    // Auto-generate slug from title
    document.getElementById('title')?.addEventListener('input', (e) => {
      const slugInput = document.getElementById('slug');
      if (slugInput && !slugInput.value.trim() || slugInput.dataset.auto === 'true') {
        slugInput.dataset.auto = 'true';
        slugInput.value = e.target.value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
      }
    });
    document.getElementById('slug')?.addEventListener('input', (e) => {
      e.target.dataset.auto = 'false';
    });
  </script>
</AdminLayout>
