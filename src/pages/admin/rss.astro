---
export const prerender = false;

import { db } from '../../db/client';
// rssSources deprecated in golden schema
import AdminLayout from '../../layouts/AdminLayout.astro';

// Basic Authentication Gate for Admin Perimeter
const authHeader = Astro.request.headers.get('Authorization');
if (!authHeader || !authHeader.startsWith('Basic ')) {
  Astro.response.headers.set('WWW-Authenticate', 'Basic realm="Bizkitgrow Admin Perimeter"');
  return new Response('Unauthorized Access', { status: 401 });
}

try {
  const credentials = Buffer.from(authHeader.split(' ')[1], 'base64').toString('ascii');
  const [username, password] = credentials.split(':');

  if (username !== import.meta.env.ADMIN_USERNAME || password !== import.meta.env.ADMIN_PASSWORD) {
    Astro.response.headers.set('WWW-Authenticate', 'Basic realm="Bizkitgrow Admin Perimeter"');
    return new Response('Unauthorized Access', { status: 401 });
  }
} catch (err) {
  Astro.response.headers.set('WWW-Authenticate', 'Basic realm="Bizkitgrow Admin Perimeter"');
  return new Response('Unauthorized Access', { status: 401 });
}

// feeds = await db.select().from(rssSources);
const activeRssFeeds = []; // Deprecated
---

<AdminLayout title="RSS Feeds Manager">
  <!-- Top Action Bar -->
  <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-8 bg-gray-900 p-6 rounded-sm border border-gray-800">
    <div>
      <h1 class="text-2xl font-heading font-black text-white tracking-tight uppercase">RSS Feeds</h1>
      <p class="text-sm font-mono text-gray-400 mt-1 uppercase tracking-widest">Manage content ingestion sources and pipelines.</p>
    </div>
  </div>

  <section class="bg-gray-900 border border-gray-800 rounded-sm p-6 sm:p-8">
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
      <h2 class="text-lg font-heading font-bold text-white uppercase tracking-tight">Active Content Feeds</h2>
      <!-- Add Feed Form -->
      <form id="add-feed-form" class="flex items-center gap-2">
        <input type="url" id="feed-url" placeholder="https://.../rss" required class="bg-black border border-gray-700 text-white font-mono text-xs rounded-sm focus:ring-brand_cta focus:border-brand_cta block w-64 p-2">
        <select id="feed-pillar" required class="bg-black border border-gray-700 text-white font-mono text-xs rounded-sm focus:ring-brand_cta focus:border-brand_cta block p-2">
          <option value="connectivity">Connectivity</option>
          <option value="reputation">Reputation</option>
          <option value="solutions">Solutions</option>
          <option value="intelligence">Intelligence</option>
        </select>
        <button type="submit" class="text-black bg-brand_cta hover:bg-brand_cta_hover font-mono font-bold rounded-sm text-xs px-4 py-2 uppercase tracking-widest transition-all whitespace-nowrap">
          Add Feed
        </button>
      </form>
    </div>
    
    <div class="overflow-x-auto">
      <table class="w-full text-sm text-left text-gray-400 font-mono">
        <thead class="text-xs text-gray-500 uppercase bg-gray-800 border-b border-gray-700">
          <tr>
            <th scope="col" class="px-6 py-3">Feed Source</th>
            <th scope="col" class="px-6 py-3">Pillar</th>
            <th scope="col" class="px-6 py-3">Status</th>
            <th scope="col" class="px-6 py-3 text-right">Last Sync</th>
            <th scope="col" class="px-6 py-3 text-right">Actions</th>
          </tr>
        </thead>
        <tbody>
          {activeRssFeeds.length > 0 ? activeRssFeeds.map((feed: any) => (
            <tr class="bg-gray-900 border-b border-gray-800 hover:bg-gray-800 transition-colors">
              <td class="px-6 py-4 font-bold text-white max-w-xs truncate">{feed.url}</td>
              <td class="px-6 py-4 capitalize">{feed.targetPillar || feed.pillar}</td>
              <td class="px-6 py-4">
                <span class={`inline-flex items-center gap-1 text-[10px] font-bold px-2 py-0.5 rounded-sm uppercase tracking-widest border ${feed.isActive ? 'bg-green-900/20 text-brand_cta border-brand_cta/30' : 'bg-gray-800 text-gray-500 border-gray-700'}`}>
                  <span class={`w-1.5 h-1.5 rounded-full ${feed.isActive ? 'bg-brand_cta' : 'bg-gray-500'}`}></span>
                  {feed.isActive ? 'ACTIVE' : 'INACTIVE'}
                </span>
              </td>
              <td class="px-6 py-4 text-right">{feed.lastFetchedAt ? new Date(feed.lastFetchedAt).toLocaleTimeString() : 'Never'}</td>
              <td class="px-6 py-4 text-right">
                {feed.id && (
                  <button data-id={feed.id} class="delete-feed-btn text-rose-500 hover:text-rose-400 font-bold text-xs transition-colors">
                    Delete
                  </button>
                )}
              </td>
            </tr>
          )) : (
            <tr>
              <td colspan="5" class="px-6 py-8 text-center text-gray-500">No active feeds found. Add one above to start ingesting content.</td>
            </tr>
          )}
        </tbody>
      </table>
    </div>
  </section>

  <script is:inline>
    // Add Feed Form Submission
    const addFeedForm = document.getElementById('add-feed-form');
    if (addFeedForm) {
      addFeedForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const url = document.getElementById('feed-url').value;
        const targetPillar = document.getElementById('feed-pillar').value;
        const submitBtn = addFeedForm.querySelector('button[type="submit"]');
        submitBtn.disabled = true;
        submitBtn.textContent = 'ADDING...';

        try {
          const res = await fetch('/api/v1/admin/feeds', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ url, targetPillar })
          });
          if (res.ok) {
            window.location.reload();
          } else {
            const data = await res.json();
            alert(`Error: ${data.error}`);
          }
        } catch (err) {
          alert('Network error adding feed.');
        } finally {
          submitBtn.disabled = false;
          submitBtn.textContent = 'ADD FEED';
        }
      });
    }

    // Delete Feed Handlers
    const deleteBtns = document.querySelectorAll('.delete-feed-btn');
    deleteBtns.forEach(btn => {
      btn.addEventListener('click', async (e) => {
        if (!confirm('Are you sure you want to delete this feed source?')) return;
        const id = e.target.getAttribute('data-id');
        e.target.disabled = true;
        e.target.textContent = '...';

        try {
          const res = await fetch(`/api/v1/admin/feeds?id=${id}`, {
            method: 'DELETE'
          });
          if (res.ok) {
            window.location.reload();
          } else {
            const data = await res.json();
            alert(`Error: ${data.error}`);
            e.target.disabled = false;
            e.target.textContent = 'Delete';
          }
        } catch (err) {
          alert('Network error deleting feed.');
          e.target.disabled = false;
          e.target.textContent = 'Delete';
        }
      });
    });
  </script>
</AdminLayout>
