---
export const prerender = false;
import LeadCaptureWidget from '../../components/LeadCaptureWidget.astro';
import LocalVisibilityScanner from '../../components/LocalVisibilityScanner.astro';
import ResellPortalWidget from '../../components/ResellPortalWidget.astro';
import Features from '../../components/widgets/Features.astro';
import GoogleReviewsWidget from '../../components/widgets/GoogleReviewsWidget.astro';
import Hero from '../../components/widgets/Hero.astro';
import SEOAuditsWidget from '../../components/widgets/SEOAuditsWidget.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const currentUrl = Astro.site
  ? new URL('/reputation', Astro.site).toString()
  : 'https://bizkitgrow.vercel.app/reputation';
---

<BaseLayout
  title="Search Authority | Bizkitgrow"
  description="Automated Google Business Profile optimization, review capture sequences, and local semantic indexation."
  canonicalUrl={currentUrl}
>
  <Hero
    tagline="PILLAR 02 // SEARCH AUTHORITY"
    title="Reputation Gating Engine"
    subtitle="Own the search grid in high-value zip codes without volatile ad spend. Automated Google Business Profile optimization and review capture."
    actions={[
      { text: 'ACTIVATE AUTHORITY', href: '#features', icon: 'tabler:seo', variant: 'primary' },
    ]}
  />

  <div class="max-w-screen-xl px-4 py-8 mx-auto grid grid-cols-1 lg:grid-cols-2 gap-8 border-b-4 border-black">
    <div class="border-4 border-black p-6 bg-white shadow-brutal">
      <ResellPortalWidget productSku="reputation-ai" resellportalStatus="active" theme="light" />
    </div>
    <div class="border-4 border-black p-6 bg-white shadow-brutal">
      <GoogleReviewsWidget />
    </div>
  </div>

  <div class="max-w-screen-xl px-4 py-12 mx-auto border-b-4 border-black">
    <div class="border-4 border-black p-6 bg-white shadow-brutal mb-12">
      <SEOAuditsWidget />
    </div>
    <LocalVisibilityScanner />
  </div>

  <Features
    id="features"
    tagline="Capabilities"
    title="Dominate Local Search"
    subtitle="Our system actively intercepts customer experiences."
    items={[
      {
        title: 'Review Gating',
        description: 'Automatically filter 5-star experiences to public platforms, while routing negative feedback to internal customer service.',
        icon: 'tabler:star',
      },
      {
        title: 'Semantic Indexation',
        description: 'Continuous content optimization aligned with the latest search engine algorithms for maximum visibility.',
        icon: 'tabler:search',
      },
      {
        title: 'Competitor Tracking',
        description: 'Real-time telemetry on competitor movements in your targeted zip codes.',
        icon: 'tabler:chart-bar',
      },
    ]}
  />

  <div class="max-w-screen-xl px-4 py-12 mx-auto">
    <LeadCaptureWidget
      title="REQUEST LOCAL SEO AUDIT"
      subtitle="Register your Google Business profile URL for a complete reputation analysis."
      serviceKey="search_authority"
      ctaText="REQUEST SEO AUDIT"
    />
  </div>
</BaseLayout>
