---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/widgets/Hero.astro';
import Features from '../../components/widgets/Features.astro';
import ResellPortalWidget from '../../components/ResellPortalWidget.astro';
import LeadCaptureWidget from '../../components/LeadCaptureWidget.astro';
import LighthouseBadge from '../../components/widgets/LighthouseBadge.astro';

const currentUrl = Astro.site ? new URL('/solutions', Astro.site).toString() : 'https://bizkitgrow.vercel.app/solutions';
---

<BaseLayout
  title="Flow Automation | Bizkitgrow"
  description="Consolidate invoicing, AI-powered scheduling, and secure e-signature workflows."
>
  <script type="application/ld+json" slot="schema" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "Bizkitgrow CRM Suite",
      "operatingSystem": "Web",
      "applicationCategory": "BusinessApplication",
      "description": "Consolidate invoicing, AI-powered scheduling, and secure e-signature workflows into a single client portal."
    }
  </script>
  <Hero
    tagline="PILLAR 03 // FLOW AUTOMATION"
    title="Operational CRM Suite"
    subtitle="Consolidate invoicing, AI-powered scheduling, and secure e-signature workflows into a single client portal."
    actions={[
      { text: 'INITIALIZE SYSTEM', href: '#features', icon: 'tabler:bolt', variant: 'primary' },
    ]}
  />

  <div class="max-w-screen-xl px-4 py-8 mx-auto grid grid-cols-1 lg:grid-cols-2 gap-8 border-b-4 border-black">
    <div class="border-4 border-black p-6 bg-white shadow-brutal">
      <ResellPortalWidget productSku="crm-suite" resellportalStatus="active" theme="light" />
    </div>
    <div class="border-4 border-black p-6 bg-white shadow-brutal flex items-center justify-center">
      <LighthouseBadge />
    </div>
  </div>

  <Features
    id="features"
    tagline="Components"
    title="Automate the Back-Office"
    subtitle="Cut administrative overhead and recover lost revenue from billing friction."
    items={[
      {
        title: 'Invoicing with AI',
        description: 'Auto-generate invoices based on CRM activity and follow up autonomously.',
        icon: 'tabler:receipt',
      },
      {
        title: 'Appointment Booking',
        description: 'Sync your calendar across timezones with intelligent buffer management.',
        icon: 'tabler:calendar',
      },
      {
        title: 'Secure E-Signatures',
        description: 'Cryptographically verified signatures for rapid contract execution.',
        icon: 'tabler:signature',
      },
    ]}
  />

  <div class="max-w-screen-xl px-4 py-12 mx-auto">
    <LeadCaptureWidget
      title="REQUEST CRM AUTOMATION DEMO"
      subtitle="Register your corporate operations to configure your custom invoicing and scheduling portal."
      serviceKey="flow_automation"
      ctaText="REQUEST AUTOMATION DEMO"
    />
  </div>
</BaseLayout>
