---
import LeadCaptureWidget from '../../components/LeadCaptureWidget.astro';
import GrowthVectors from '../../components/widgets/GrowthVectors.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const currentUrl = Astro.site
  ? new URL('/solutions', Astro.site).toString()
  : 'https://bizkitgrow.vercel.app/solutions';
---

<BaseLayout
  title="B2B Operational Solutions | Bizkitgrow"
  description="Scale your remote business with global VPN infrastructure, algorithmic SEO, and autonomous operational AI."
  canonicalUrl={currentUrl}
>
  <div class="pt-16 pb-8 bg-canvas_accent border-b-4 border-black">
    <div class="max-w-7xl mx-auto px-6">
      <div class="font-mono text-sm font-black text-brand_cta mb-4 tracking-widest uppercase">
        [ SYSTEM ARCHITECTURE ]
      </div>
      <h1 class="font-heading text-5xl md:text-7xl font-black text-black uppercase tracking-tight mb-6">
        Operational<br />Solutions.
      </h1>
      <p class="text-xl text-gray-700 font-medium max-w-3xl leading-relaxed">
        We provide the foundational infrastructure required to run a global operation. From secure VPN tunneling to autonomous client acquisition and automated invoicing, deploy exactly what you need.
      </p>
    </div>
  </div>

  <GrowthVectors />

  <div class="max-w-7xl mx-auto px-6 py-20">
    <LeadCaptureWidget
      title="REQUEST CUSTOM ARCHITECTURE"
      subtitle="Speak with an operational engineer to design a custom deployment across our three growth pillars."
      serviceKey="custom_architecture"
      ctaText="REQUEST DEPLOYMENT DEMO"
    />
  </div>
</BaseLayout>
