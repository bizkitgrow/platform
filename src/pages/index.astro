---
import { desc } from 'drizzle-orm';
import brandManifest from '../../config/brand_manifest.json';
import systemArchitecture from '../../config/system_architecture.json';
import { db } from '../db/client';
import { posts as postsTable } from '../db/schema';

import LeadCaptureWidget from '../components/LeadCaptureWidget.astro';
import ResellPortalWidget from '../components/ResellPortalWidget.astro';
import BlogHighlightedPosts from '../components/widgets/BlogHighlightedPosts.astro';
import CallToAction from '../components/widgets/CallToAction.astro';
import Features from '../components/widgets/Features.astro';
import GrowthVectors from '../components/widgets/GrowthVectors.astro';
import Hero from '../components/widgets/Hero.astro';
import Stats from '../components/widgets/Stats.astro';
import Steps from '../components/widgets/Steps.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const brandName = systemArchitecture.tenant_settings.brand_name;
const currentUrl = Astro.site ? Astro.site.toString() : 'https://bizkitgrow.vercel.app/';

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: brandName,
  url: currentUrl,
  description:
    'Bizkitgrow helps remote businesses scale with global eSIM connectivity, local SEO tools, and automated invoicing.',
  sameAs: [Astro.site ? Astro.site.origin : 'https://bizkitgrow.vercel.app'],
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'customer service',
    email: systemArchitecture.tenant_settings.support_email,
  },
};

let recentPosts: any[] = [];
try {
  recentPosts = await db.select().from(postsTable).orderBy(desc(postsTable.createdAt)).limit(2);
} catch (err: any) {
  console.error('Database query failed for index:', err.message);
}

const showPendingWidgets = Astro.url.searchParams.get('preview') === 'true' || false;

const displayPosts =
  recentPosts.length > 0
    ? recentPosts.map((p) => ({
        title: p.title,
        slug: p.slug,
        excerpt: p.metaDesc || 'Read the complete analysis from the Bizkitgrow intelligence feed.',
        publishDate: p.createdAt ? new Date(p.createdAt) : new Date(),
        image:
          p.originalImage ||
          `https://image.pollinations.ai/prompt/${encodeURIComponent(`${p.title}, brutalist style tech card, corporate minimalism`)}?width=600&height=400&nologo=true`,
        tags: [p.targetProductSku || 'ai_business_tools_suite'],
        readingTime: `${Math.max(2, Math.ceil((p.content?.length || 1000) / 1500))} min read`,
        pillar: p.targetProductSku || 'ai_business_tools_suite',
        createdAt: p.createdAt
          ? new Date(p.createdAt).toLocaleDateString('en-US', {
              month: 'short',
              day: 'numeric',
              year: 'numeric',
            })
          : 'Jul 4, 2026',
      }))
    : [];
---

<BaseLayout
  title="Bizkitgrow | Remote Business & Local SEO Software"
  description="Manage your global team's connectivity, dominate local search results, and handle invoicing from one dashboard."
  canonicalUrl={currentUrl}
>
  <script type="application/ld+json" slot="schema" is:inline set:html={JSON.stringify(orgSchema)} />

  <Hero
    actions={[
      { text: brandManifest.audience_demand_matrix.intent_clusters.pillar_1_mobility.conversion_copy_tokens.cta_label.toUpperCase(), href: '/solutions/crm-system', icon: 'tabler:arrow-right', variant: 'primary' },
      { text: 'READ GUIDES', href: '/blog' }
    ]}
  >
    <Fragment slot="title">
      Scale Your Remote Agency. <br />
      <span class="text-brand_cta dark:text-brand_cta highlight">Without the Administrative Friction.</span>
    </Fragment>

    <Fragment slot="subtitle">
      Bizkitgrow helps remote agencies and cross-border consultants connect teams instantly with global eSIM data, auto-collect customer reviews, and streamline B2B invoicing from a single, unified client portal.
    </Fragment>
  </Hero>

  <Stats
    stats={[
      { title: 'Countries Supported', amount: '190+' },
      { title: 'Setup Time', amount: '< 5 Mins' },
      { title: 'Automated Tasks', amount: '100%' },
      { title: 'Uptime', amount: '99.9%' },
    ]}
  />

  <Features
    id="features"
    tagline="FEATURES"
    title="Everything you need to operate globally and rank locally."
    subtitle="Built for digital nomads, agencies, and service businesses."
    items={[
      {
        title: 'Global eSIM Connectivity',
        description: 'Instant cellular data in 190+ countries — no SIM swaps, no roaming bills. Your team stays connected on the ground, in transit, or working from a beach.',
        icon: 'tabler:wifi',
      },
      {
        title: 'Local SEO & Reputation Engine',
        description: 'Turn satisfied clients into visible proof. Auto-collect Google reviews, surface your business at the top of local results, and defend your reputation — hands-free.',
        icon: 'tabler:seo',
      },
      {
        title: 'CRM & Smart Invoicing',
        description: 'Eliminate the late-payment cycle. Send professional invoices, accept online payments, and manage every client interaction in one clean, audit-ready portal.',
        icon: 'tabler:bolt',
      },
      {
        title: 'Live Market Intelligence',
        description: 'Real-time crypto prices, global equity charts, and macro intelligence feeds — aggregated from CoinGecko, TradingView, and Finnhub. Decisions backed by data, not noise.',
        icon: 'tabler:chart-bar',
        callToAction: {
          text: 'Open Market Terminal →',
          href: '/blog#market',
        },
      },
    ]}
  />

  <GrowthVectors />

  <Steps
    title="Start growing your business in minutes."
    items={[
      {
        title: 'Step 1: <span class="font-medium">Create Your Account</span>',
        description: 'Sign up for free and tell us what you need: connectivity, local SEO, or billing.',
        icon: 'tabler:user-plus',
      },
      {
        title: 'Step 2: <span class="font-medium">Connect Your Tools</span>',
        description: 'Link your Google Business Profile or download your first eSIM instantly.',
        icon: 'tabler:settings',
      },
      {
        title: 'Step 3: <span class="font-medium">Automate Your Work</span>',
        description: 'Let Bizkitgrow automatically gather reviews and send invoice reminders while you focus on your clients.',
        icon: 'tabler:rocket',
      },
      {
        title: 'Ready to launch!',
        icon: 'tabler:check',
      },
    ]}
    image={{
      src: '/assets/steps-diagram.png',
      alt: 'Bizkitgrow Dashboard Overview',
    }}
  />

  <!-- Blog Highlighted Posts (activated dynamically using database posts) -->
  {displayPosts.length > 0 && (
    <BlogHighlightedPosts
      title="Latest B2B Insights"
      information="Expert insights on global connectivity, local SEO dominance, and agency automation."
      posts={displayPosts}
    />
  )}

  <!-- Resell Portal Widget (hidden behind feature flag preview parameter since it is pending) -->
  {showPendingWidgets && (
    <div class="max-w-screen-xl px-4 py-8 mx-auto border-b-4 border-black">
      <div class="border-4 border-black p-6 bg-white shadow-brutal">
        <ResellPortalWidget productSku="ai-blog-generator" resellportalStatus="pending" theme="light" />
      </div>
    </div>
  )}

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'GET STARTED FOR FREE',
        href: '/solutions/crm-system',
        icon: 'tabler:arrow-right',
      },
    ]}
  >
    <Fragment slot="title">
      Ready to get more customers?
    </Fragment>

    <Fragment slot="subtitle">
      Join business owners who are saving hours every week with automated tools and global connectivity.
    </Fragment>
  </CallToAction>

  <div class="max-w-screen-xl px-4 py-12 mx-auto">
    <LeadCaptureWidget
      title="JOIN THE WAITING LIST"
      subtitle="Sign up today to reserve your spot and receive early-bird pricing when we launch our full suite."
      serviceKey="waiting_list"
      ctaText="SECURE MY SPOT"
    />
  </div>
</BaseLayout>
