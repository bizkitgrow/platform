---
import { desc } from 'drizzle-orm';
import brandManifest from '../../config/brand_manifest.json';
import systemArchitecture from '../../config/system_architecture.json';
import targetSolutions from '../../config/target_solutions.json';
import { db } from '../db/client';
import { posts as postsTable } from '../db/schema';

import LeadCaptureWidget from '../components/LeadCaptureWidget.astro';
import ResellPortalWidget from '../components/ResellPortalWidget.astro';
import BlogHighlightedPosts from '../components/widgets/BlogHighlightedPosts.astro';
import CallToAction from '../components/widgets/CallToAction.astro';
import Features from '../components/widgets/Features.astro';
import GrowthVectors from '../components/widgets/GrowthVectors.astro';
import Hero from '../components/widgets/Hero.astro';
import Stats from '../components/widgets/Stats.astro';
import Steps from '../components/widgets/Steps.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const brandName =
  brandManifest.brand_architecture.name || systemArchitecture.tenant_settings.brand_name;
const currentUrl = Astro.site ? Astro.site.toString() : 'https://bizkitgrow.vercel.app/';

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: brandName,
  url: currentUrl,
  description: brandManifest.brand_architecture.global_positioning,
  sameAs: [Astro.site ? Astro.site.origin : 'https://bizkitgrow.vercel.app'],
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'customer service',
    email: systemArchitecture.tenant_settings.support_email,
  },
};

let recentPosts: any[] = [];
try {
  recentPosts = await db.select().from(postsTable).orderBy(desc(postsTable.createdAt)).limit(2);
} catch (err: any) {
  console.error('Database query failed for index:', err.message);
}

const showPendingWidgets = Astro.url.searchParams.get('preview') === 'true' || false;

const displayPosts =
  recentPosts.length > 0
    ? recentPosts.map((p) => ({
        title: p.title,
        slug: p.slug,
        excerpt: p.metaDesc || 'Read our latest business insights.',
        publishDate: p.createdAt ? new Date(p.createdAt) : new Date(),
        image:
          p.originalImage ||
          `https://image.pollinations.ai/prompt/${encodeURIComponent(`${p.title}, corporate minimalist`)}?width=600&height=400&nologo=true`,
        tags: [p.targetProductSku || 'business_tools'],
        readingTime: `${Math.max(2, Math.ceil((p.content?.length || 1000) / 1500))} min read`,
        pillar: p.targetProductSku || 'business_tools',
        createdAt: p.createdAt
          ? new Date(p.createdAt).toLocaleDateString('en-US', {
              month: 'short',
              day: 'numeric',
              year: 'numeric',
            })
          : 'Jul 4, 2026',
      }))
    : [];

// Map top 4 solutions for Features section
const topFeatures = targetSolutions.slice(0, 4).map((solution) => ({
  title: solution.name,
  description: solution.short_description,
  icon:
    solution.pillar === 'infrastructure'
      ? 'tabler:server'
      : solution.pillar === 'authority'
        ? 'tabler:chart-arrows'
        : 'tabler:bolt',
  callToAction: {
    text: 'Learn more →',
    href: `/solutions/${solution.slug}`,
  },
}));
---

<BaseLayout
  title={`${brandName} | The Ultimate Toolkit for Agencies`}
  description={brandManifest.brand_architecture.global_positioning}
  canonicalUrl={currentUrl}
>
  <script type="application/ld+json" slot="schema" is:inline set:html={JSON.stringify(orgSchema)} />

  <Hero
    actions={[
      { text: brandManifest.audience_demand_matrix.intent_clusters.solutions.conversion_copy_tokens.cta_label.toUpperCase(), href: '/solutions/crm-system', icon: 'tabler:arrow-right', variant: 'primary' },
      { text: 'READ GUIDES', href: '/blog' }
    ]}
  >
    <Fragment slot="title">
      <span class="text-brand_cta dark:text-brand_cta highlight">{brandManifest.audience_demand_matrix.intent_clusters.solutions.conversion_copy_tokens.hero_headline}</span>
    </Fragment>

    <Fragment slot="subtitle">
      {brandManifest.brand_architecture.global_positioning}
    </Fragment>
  </Hero>

  <Stats
    stats={[
      { title: 'Global Reach', amount: '190+ Countries' },
      { title: 'Deployment', amount: 'Instant' },
      { title: 'Automated Workflows', amount: '100%' },
      { title: 'Platform Uptime', amount: '99.9%' },
    ]}
  />

  <Features
    id="features"
    tagline="SOLUTIONS"
    title="Everything you need to operate and grow."
    subtitle="Enterprise-grade tools simplified for remote teams and agencies."
    items={topFeatures}
  />

  <GrowthVectors />

  <Steps
    title="Scale Your Business in Three Steps"
    items={[
      {
        title: 'Step 1: <span class="font-medium">Setup Infrastructure</span>',
        description: 'Deploy secure VPNs, cloud storage, and hosting for your remote team instantly.',
        icon: 'tabler:server-cog',
      },
      {
        title: 'Step 2: <span class="font-medium">Automate Operations</span>',
        description: 'Connect your CRM, invoicing, and scheduling tools into one seamless workflow.',
        icon: 'tabler:bolt',
      },
      {
        title: 'Step 3: <span class="font-medium">Build Authority</span>',
        description: 'Dominate search rankings and automate social media to attract high-intent clients.',
        icon: 'tabler:chart-arrows-vertical',
      },
      {
        title: 'Ready to launch.',
        icon: 'tabler:check',
      },
    ]}
  />

  {displayPosts.length > 0 && (
    <BlogHighlightedPosts
      title="Latest Strategies"
      information="Actionable advice on scaling agencies, improving SEO, and managing remote teams."
      posts={displayPosts}
    />
  )}

  {showPendingWidgets && (
    <div class="max-w-screen-xl px-4 py-8 mx-auto border-b-4 border-black">
      <div class="border-4 border-black p-6 bg-white shadow-brutal">
        <ResellPortalWidget productSku="ai-blog-generator" resellportalStatus="pending" theme="light" />
      </div>
    </div>
  )}

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'GET STARTED TODAY',
        href: '/solutions',
        icon: 'tabler:arrow-right',
      },
    ]}
  >
    <Fragment slot="title">
      Ready to streamline your business?
    </Fragment>

    <Fragment slot="subtitle">
      Join thousands of professionals using our tools to save time and increase revenue.
    </Fragment>
  </CallToAction>

  <div class="max-w-screen-xl px-4 py-12 mx-auto">
    <LeadCaptureWidget
      title="STAY UPDATED"
      subtitle="Join our newsletter for the latest platform updates and business growth strategies."
      serviceKey="newsletter"
      ctaText="SUBSCRIBE NOW"
    />
  </div>
</BaseLayout>
