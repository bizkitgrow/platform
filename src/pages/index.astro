---
import { desc } from 'drizzle-orm';
import { db } from '../db/client';
import { posts as postsTable } from '../db/schema';
import systemArchitecture from '../../system_architecture.json';
import brandManifest from '../../config/brand_manifest.json';

import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/widgets/Hero.astro';
import Features from '../components/widgets/Features.astro';
import Stats from '../components/widgets/Stats.astro';
import Steps from '../components/widgets/Steps.astro';
import CallToAction from '../components/widgets/CallToAction.astro';
import BlogHighlightedPosts from '../components/widgets/BlogHighlightedPosts.astro';
import ResellPortalWidget from '../components/ResellPortalWidget.astro';

const brandName = systemArchitecture.tenant_settings.brand_name;
const currentUrl = 'https://bizkitgrow.vercel.app/';

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: brandName,
  url: currentUrl,
  description: 'Autonomous B2B infrastructure for global remote operators: sovereign connectivity, reputation gating, and back-office automation.',
  sameAs: ['https://bizkitgrow.vercel.app'],
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'customer service',
    email: systemArchitecture.tenant_settings.support_email,
  },
};

let recentPosts: any[] = [];
try {
  recentPosts = await db.select().from(postsTable).orderBy(desc(postsTable.createdAt)).limit(2);
} catch (err: any) {
  console.error('Database query failed for index:', err.message);
}

const displayPosts =
  recentPosts.length > 0
    ? recentPosts.map((p) => ({
        title: p.title,
        slug: p.slug,
        excerpt: p.metaDesc || 'Read the complete analysis from the Bizkitgrow intelligence feed.',
        publishDate: p.createdAt ? new Date(p.createdAt) : new Date(),
        image: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=1740&q=80',
        tags: [p.targetProductSku || 'ai_business_tools_suite'],
      }))
    : [];
---

<BaseLayout
  title="Sovereign B2B Digital Infrastructure"
  description="Consolidate global eSIM connectivity, automated local search authority, and back-office pipelines under a single secure perimeter."
  canonicalUrl={currentUrl}
>
  <script type="application/ld+json" slot="schema" is:inline set:html={JSON.stringify(orgSchema)} />

  <Hero
    actions={[
      { text: 'ACCESS PLATFORM', href: '/solutions/crm-system', icon: 'tabler:arrow-right', variant: 'primary' },
      { text: 'VIEW INTELLIGENCE FEED', href: '/blog' }
    ]}
  >
    <Fragment slot="title">
      Sovereign B2B <br />
      <span class="text-brand_cta dark:text-brand_cta highlight">Digital Logistics.</span>
    </Fragment>

    <Fragment slot="subtitle">
      Scale global B2B connectivity, automate local brand authority, and streamline customer flows from a single unified portal. Built for international enterprises and remote teams who demand speed, security, and zero operational friction.
    </Fragment>
  </Hero>

  <Stats
    stats={[
      { title: 'Countries Covered', amount: '190+' },
      { title: 'Core Pillars', amount: '3' },
      { title: 'Automated', amount: '100%' },
      { title: 'Edge Latency', amount: '<420ms' },
    ]}
  />

  <Features
    id="features"
    tagline="PILLARS"
    title="Select Your Operational Perimeter."
    subtitle="Growth Vectors"
    items={[
      {
        title: 'Global eSIM Infrastructure',
        description: 'Instant cellular routing across 190+ sovereign networks. Enterprise-grade eSIM provisioning with dedicated financial-grade encryption — no roaming friction, full uptime guarantee.',
        icon: 'tabler:wifi',
      },
      {
        title: 'Reputation Gating Engine',
        description: 'Automated Google Business Profile optimization, review capture sequences, and local semantic indexation. Own the search grid in high-value zip codes without volatile ad spend.',
        icon: 'tabler:seo',
      },
      {
        title: 'Operational CRM Suite',
        description: 'Consolidate invoicing, AI-powered scheduling, and secure e-signature workflows into a single client portal. Cut administrative overhead and recover lost revenue from billing friction.',
        icon: 'tabler:bolt',
      },
    ]}
  />

  <Steps
    title="Get your infrastructure running in minutes."
    items={[
      {
        title: 'Step 1: <span class="font-medium">Sign up</span>',
        description: 'Create your operator account securely. No credit card required for initial setup.',
        icon: 'tabler:user-plus',
      },
      {
        title: 'Step 2: <span class="font-medium">Configure routing</span>',
        description: 'Set your preferred target regions and active product SKUs.',
        icon: 'tabler:settings',
      },
      {
        title: 'Step 3: <span class="font-medium">Deploy connectivity</span>',
        description: 'Your digital presence goes live. AI agents begin crawling for search authority immediately.',
        icon: 'tabler:rocket',
      },
      {
        title: 'Ready!',
        icon: 'tabler:check',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=1740&q=80',
      alt: 'Dashboard abstract',
    }}
  />

  <div class="max-w-screen-xl px-4 py-8 mx-auto border-b border-borders_subtle">
    <ResellPortalWidget productSku="ai-blog-generator" resellportalStatus="pending" theme="dark" />
  </div>

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'INITIALIZE ONBOARDING QUEUE',
        href: '/solutions/crm-system',
        icon: 'tabler:download',
      },
    ]}
  >
    <Fragment slot="title">
      Secure Your Position in the Queue.
    </Fragment>

    <Fragment slot="subtitle">
      Early operators receive 30% off first 3 months, dedicated onboarding, and direct access to the operational intelligence feed.
    </Fragment>
  </CallToAction>
</BaseLayout>
