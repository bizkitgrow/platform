---
import { desc } from 'drizzle-orm';
import brandManifest from '../../config/brand_manifest.json';
import systemArchitecture from '../../config/system_architecture.json';
import targetSolutions from '../../config/target_solutions.json';
import { db } from '../db/client';
import { posts as postsTable } from '../db/schema';
import BaseLayout from '../layouts/BaseLayout.astro';
import { Button } from '../components/ui/button';
import { Badge } from '../components/ui/badge';
import { Card, CardHeader, CardTitle, CardDescription, CardContent, CardFooter } from '../components/ui/card';

const brandName = brandManifest.brand_architecture.name || systemArchitecture.tenant_settings.brand_name;
const currentUrl = Astro.site ? Astro.site.toString() : 'https://bizkitgrow.vercel.app/';

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: brandName,
  url: currentUrl,
  description: brandManifest.brand_architecture.global_positioning,
  sameAs: [Astro.site ? Astro.site.origin : 'https://bizkitgrow.vercel.app'],
};

let recentPosts: any[] = [];
try {
  recentPosts = await db.select().from(postsTable).orderBy(desc(postsTable.createdAt)).limit(2);
} catch (err: any) {
  console.error('Database query failed for index:', err.message);
}

const displayPosts =
  recentPosts.length > 0
    ? recentPosts.map((p) => ({
        title: p.title,
        slug: p.slug,
        excerpt: p.metaDesc || 'Read our latest business insights.',
        image: p.originalImage || `https://image.pollinations.ai/prompt/${encodeURIComponent(`${p.title}, corporate minimalist`)}?width=600&height=400&nologo=true`,
        createdAt: p.createdAt ? new Date(p.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : 'Jul 4, 2026',
      }))
    : [];

const topFeatures = targetSolutions.slice(0, 4);
---

<BaseLayout
  title={`${brandName} | The Ultimate Toolkit for Agencies`}
  description={brandManifest.brand_architecture.global_positioning}
  canonicalUrl={currentUrl}
>
  <script type="application/ld+json" slot="schema" is:inline set:html={JSON.stringify(orgSchema)} />

  <!-- Hero Section (SaaS / Minimalist Hybrid) -->
  <section class="relative py-24 md:py-32 lg:py-40 overflow-hidden border-b border-border bg-background">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center max-w-4xl relative z-10">
      <Badge variant="outline" className="mb-6 uppercase tracking-widest text-[10px] font-mono rounded-full px-3 py-1 bg-background text-foreground border-border">
        V2.0 is Live
      </Badge>
      <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight text-foreground mb-8 leading-[1.1] font-heading">
        {brandManifest.audience_demand_matrix.intent_clusters.solutions.conversion_copy_tokens.hero_headline}
      </h1>
      <p class="text-xl md:text-2xl text-muted-foreground mb-10 max-w-2xl mx-auto leading-relaxed">
        {brandManifest.brand_architecture.global_positioning}
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/solutions/crm-system">
          <Button size="lg" className="w-full sm:w-auto text-sm tracking-wide h-14 px-8 uppercase font-bold rounded-none bg-primary text-primary-foreground hover:bg-primary/90">
            {brandManifest.audience_demand_matrix.intent_clusters.solutions.conversion_copy_tokens.cta_label}
          </Button>
        </a>
        <a href="/blog">
          <Button variant="outline" size="lg" className="w-full sm:w-auto text-sm tracking-wide h-14 px-8 uppercase font-bold rounded-none border-border bg-background hover:bg-muted text-foreground">
            Read Guides
          </Button>
        </a>
      </div>
    </div>
  </section>

  <!-- Solutions/Features Grid -->
  <section class="py-24 bg-muted/30 border-b border-border">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 max-w-2xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-foreground mb-4 font-heading">Enterprise-grade tools, simplified.</h2>
        <p class="text-lg text-muted-foreground">Everything you need to operate, automate, and grow your agency remotely.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto">
        {topFeatures.map((feature) => (
          <Card className="rounded-none border border-border shadow-none hover:border-primary/50 transition-colors bg-background">
            <CardHeader>
              <CardTitle className="text-xl text-foreground font-heading">{feature.name}</CardTitle>
              <CardDescription className="text-sm font-mono mt-2 text-muted-foreground">{feature.pillar.toUpperCase()}</CardDescription>
            </CardHeader>
            <CardContent>
              <p class="text-muted-foreground leading-relaxed">{feature.short_description}</p>
            </CardContent>
            <CardFooter>
              <a href={`/solutions/${feature.slug}`} class="text-sm font-bold uppercase tracking-wider text-primary hover:underline flex items-center gap-2">
                Learn more
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
              </a>
            </CardFooter>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- Intelligence / Blog Section -->
  {displayPosts.length > 0 && (
    <section class="py-24 bg-background">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
        <div class="flex items-end justify-between mb-12">
          <div>
            <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-foreground font-heading">Intelligence</h2>
            <p class="text-lg text-muted-foreground mt-2">Actionable advice on scaling agencies.</p>
          </div>
          <a href="/blog" class="hidden sm:block text-sm font-bold uppercase tracking-wider text-primary hover:underline">View All</a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {displayPosts.map((post) => (
            <a href={`/blog/${post.slug}`} class="group block">
              <div class="aspect-[16/9] mb-4 overflow-hidden border border-border">
                <img src={post.image} alt={post.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
              </div>
              <div class="flex items-center gap-4 text-xs font-mono text-muted-foreground uppercase tracking-wider mb-2">
                <span>{post.createdAt}</span>
              </div>
              <h3 class="text-xl font-bold leading-snug text-foreground group-hover:text-primary transition-colors font-heading">{post.title}</h3>
              <p class="mt-2 text-muted-foreground line-clamp-2 leading-relaxed">{post.excerpt}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Final CTA -->
  <section class="py-32 bg-primary text-primary-foreground text-center">
    <div class="container mx-auto px-4 max-w-3xl">
      <h2 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-6 font-heading">Ready to streamline your business?</h2>
      <p class="text-xl mb-10 text-primary-foreground/80 leading-relaxed">Join thousands of professionals using our tools to save time and increase revenue.</p>
      <a href="/solutions">
        <Button size="lg" variant="secondary" className="text-sm tracking-wide h-14 px-12 uppercase font-bold rounded-none bg-background text-foreground hover:bg-muted">
          Get Started Today
        </Button>
      </a>
    </div>
  </section>
</BaseLayout>
