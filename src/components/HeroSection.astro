---
interface Props {
  badge?: string;
  title: string;
  subtitle: string;
  primaryCtaText: string;
  primaryCtaLink: string;
  secondaryCtaText?: string;
  secondaryCtaLink?: string;
}

const {
  badge,
  title,
  subtitle,
  primaryCtaText,
  primaryCtaLink,
  secondaryCtaText,
  secondaryCtaLink,
} = Astro.props;
---

<section class="relative pt-24 pb-32 overflow-hidden">
  <!-- Decorative background elements -->
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-emerald-50 via-white to-white"></div>
  <div class="absolute top-0 right-0 -translate-y-12 translate-x-1/3 w-[800px] h-[800px] opacity-30 bg-gradient-to-tr from-emerald-100 to-teal-50 blur-3xl rounded-full mix-blend-multiply pointer-events-none"></div>
  
  <div class="max-w-[1280px] mx-auto px-6 text-center">
    {badge && (
      <div class="inline-flex items-center px-3 py-1 mb-8 text-xs font-semibold tracking-wide text-brand_cta bg-emerald-50 rounded-full border border-emerald-100 ring-1 ring-inset ring-emerald-200/50">
        {badge}
      </div>
    )}
    
    <h1 class="max-w-4xl mx-auto text-5xl md:text-6xl font-extrabold tracking-tight text-text_primary leading-[1.1] mb-8">
      <Fragment set:html={title} />
    </h1>
    
    <p class="max-w-2xl mx-auto text-lg md:text-xl text-text_secondary leading-relaxed mb-10">
      {subtitle}
    </p>
    
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href={primaryCtaLink} class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-3.5 text-base font-semibold text-white bg-brand_cta hover:bg-brand_cta_hover rounded-xl shadow-subtle hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200">
        {primaryCtaText}
      </a>
      
      {secondaryCtaText && secondaryCtaLink && (
        <a href={secondaryCtaLink} class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-3.5 text-base font-semibold text-text_primary bg-white hover:bg-canvas_accent border border-borders_subtle rounded-xl shadow-sm transition-colors duration-200">
          {secondaryCtaText}
        </a>
      )}
    </div>
  </div>
</section>
