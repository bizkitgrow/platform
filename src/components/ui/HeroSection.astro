---
interface Props {
  headline: string;
  subheadline: string;
  ctaLabel: string;
  sku: string;
}

const { headline, subheadline, ctaLabel, sku } = Astro.props;

import CheckoutButton from './CheckoutButton.astro';
---

<section class="relative overflow-hidden py-24 md:py-32 bg-slate-50 border-b border-slate-100">
  <div class="max-w-[1280px] mx-auto px-6 relative z-10 flex flex-col items-center text-center">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-emerald-50 border border-emerald-100 text-emerald-700 text-xs font-semibold uppercase tracking-wider mb-6">
      <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
      Sovereign Growth Engine Active
    </div>
    
    <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold text-slate-900 tracking-tight max-w-4xl leading-tight mb-8">
      {headline}
    </h1>
    
    <p class="text-lg sm:text-xl text-slate-500 max-w-2xl leading-relaxed mb-10">
      {subheadline}
    </p>
    
    <div class="flex flex-col sm:flex-row items-center gap-4">
      <CheckoutButton sku={sku} className="h-12 px-8 text-base tracking-wide font-extrabold min-w-[200px]">
        {ctaLabel}
      </CheckoutButton>
      <a href="#waitlist" class="h-12 px-8 inline-flex items-center justify-center rounded-xl border border-slate-200 hover:border-slate-300 bg-white text-slate-700 text-sm font-semibold transition-all">
        Consult Infrastructure
      </a>
    </div>
  </div>
</section>
