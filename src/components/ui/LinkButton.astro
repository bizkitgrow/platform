---
import type { AstroComponentFactory } from 'astro';

/**
 * A plain anchor styled as a button using the project's Oklch design tokens.
 * Usage: <LinkButton href="/path" class="extra classes">Label</LinkButton>
 */
export interface Props {
  href: string;
  target?: string;
  rel?: string;
  class?: string;
}
---
<a
  href={Astro.props.href}
  target={Astro.props.target ?? "_self"}
  rel={Astro.props.rel ?? (Astro.props.target === "_blank" ? "noopener noreferrer" : undefined)}
  class={
    `inline-block px-6 py-3 font-mono text-sm font-bold uppercase transition-all duration-200 hover:translate-y-0.5 ` +
    (Astro.props.class ?? "bg-brand_cta text-white border-2 border-black hover:bg-black hover:text-white")
  }
>
  <slot />
</a>
