---
import { getProductBySku } from '../utils/products';

interface Props {
  sku: string;
  class?: string;
}

const { sku, class: className } = Astro.props as Props;
const product = getProductBySku(sku);

if (!product) {
  throw new Error(`[ProductCallout] SKU "${sku}" is not registered in the product catalog.`);
}
---

<div class:list={["bg-white border-4 border-black p-6 sm:p-8 my-8 shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] max-w-2xl mx-auto text-left transition-all", className]}>
  <span class="font-mono text-[10px] font-black tracking-widest text-teal-600 dark:text-teal-500 uppercase block mb-2">
    // SYSTEM_SOLUTIONS_PILLAR: {product.pillar}
  </span>
  <h2 class="font-heading text-xl sm:text-2xl font-black text-slate-900 tracking-tight leading-tight mb-3">
    {product.title}
  </h2>
  <p class="font-body text-sm sm:text-base text-slate-600 leading-relaxed mb-6">
    {product.subtitle}
  </p>
  
  <div class="prose-brutalist font-mono text-xs text-slate-700 font-bold mb-8 space-y-2">
    <Fragment set:html={product.description} />
  </div>

  <a 
    href={product.href} 
    class="inline-block w-full text-center bg-black text-white hover:bg-teal-600 hover:text-white font-mono font-black tracking-wider text-xs uppercase px-6 py-4 border-2 border-black shadow-[4px_4px_0px_0px_rgba(13,148,136,1)] hover:shadow-none active:translate-x-1 active:translate-y-1 transition-all"
  >
    {product.actionLabel} ──>
  </a>
</div>
