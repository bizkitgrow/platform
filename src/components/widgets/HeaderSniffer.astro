---
// HeaderSniffer.astro
---
<div class="widget-container" style="border: 1px solid oklch(var(--border)); padding: 1.5rem; border-radius: 0.5rem; background: oklch(var(--background));">
  <h3 style="color: oklch(var(--primary)); font-weight: bold; margin-bottom: 1rem;">Header Sniffer</h3>
  <div style="display: flex; gap: 0.5rem; margin-bottom: 1rem;">
    <input type="url" id="sniffer-url" placeholder="https://example.com" value="https://example.com" style="flex: 1; padding: 0.5rem; border: 1px solid oklch(var(--border)); border-radius: 0.25rem; background: transparent;" />
    <button id="sniffer-btn" style="background: oklch(var(--primary)); color: white; border: none; padding: 0.5rem 1rem; border-radius: 0.25rem; cursor: pointer;">Sniff</button>
  </div>
  
  <pre id="sniffer-output" style="font-family: monospace; background: rgba(0,0,0,0.05); padding: 1rem; border-radius: 0.25rem; overflow-x: auto; max-height: 300px; margin: 0;">Enter a URL and click Sniff to view headers.</pre>
</div>

<script>
  (function() {
    const btn = document.getElementById('sniffer-btn');
    const input = document.getElementById('sniffer-url');
    const output = document.getElementById('sniffer-output');
    
    if (!btn || !input || !output) return;

    btn.addEventListener('click', async () => {
      const url = input.value.trim();
      if (!url) return;
      
      output.textContent = 'Fetching headers...';
      
      try {
        // We use fetch with method HEAD if possible, or GET.
        // Note: Many sites block CORS for cross-origin fetches on the client.
        const response = await fetch(url, { method: 'GET', mode: 'cors' });
        const headersObj = {};
        response.headers.forEach((value, key) => {
          headersObj[key] = value;
        });
        
        output.textContent = JSON.stringify(headersObj, null, 2);
      } catch (e) {
        output.textContent = `Error fetching headers for ${url}.\nThis is usually due to CORS restrictions preventing client-side fetches to this domain.\n\nError: ${e.message}`;
      }
    });
  })();
</script>
