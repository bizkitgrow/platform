---
// RatingSolver.astro
---
<div class="widget-container" style="border: 1px solid oklch(var(--border)); padding: 1.5rem; border-radius: 0.5rem; background: oklch(var(--background));">
  <h3 style="color: oklch(var(--primary)); font-weight: bold; margin-bottom: 1rem;">Reputation Rating Solver</h3>
  
  <div style="display: flex; flex-direction: column; gap: 1rem;">
    <div>
      <label style="display: block; margin-bottom: 0.25rem;">Current Average Rating: <span id="current-rating-val">4.2</span></label>
      <input type="range" id="current-rating" min="1" max="4.9" step="0.1" value="4.2" style="width: 100%;" />
    </div>
    
    <div>
      <label style="display: block; margin-bottom: 0.25rem;">Total Current Reviews: <span id="current-reviews-val">50</span></label>
      <input type="range" id="current-reviews" min="1" max="1000" step="1" value="50" style="width: 100%;" />
    </div>
    
    <div>
      <label style="display: block; margin-bottom: 0.25rem;">Target Average Rating: <span id="target-rating-val">4.5</span></label>
      <input type="range" id="target-rating" min="1.1" max="5.0" step="0.1" value="4.5" style="width: 100%;" />
    </div>
    
    <div style="background: rgba(0,0,0,0.03); padding: 1rem; border-radius: 0.25rem; text-align: center; margin-top: 0.5rem;">
      <p style="margin: 0; font-size: 0.9rem;">You need approximately</p>
      <h2 id="required-5stars" style="margin: 0.5rem 0; color: oklch(var(--primary)); font-size: 2.5rem;">30</h2>
      <p style="margin: 0; font-size: 0.9rem;">new 5-star reviews to reach your target.</p>
    </div>
  </div>
</div>

<script>
  (function() {
    const inputs = {
      rating: document.getElementById('current-rating'),
      reviews: document.getElementById('current-reviews'),
      target: document.getElementById('target-rating')
    };
    
    const displays = {
      rating: document.getElementById('current-rating-val'),
      reviews: document.getElementById('current-reviews-val'),
      target: document.getElementById('target-rating-val'),
      result: document.getElementById('required-5stars')
    };
    
    function calculate() {
      const r = parseFloat(inputs.rating.value);
      const n = parseInt(inputs.reviews.value, 10);
      let t = parseFloat(inputs.target.value);
      
      // Target must be higher than current to make sense for 5-star solving
      if (t <= r) {
        displays.result.textContent = '0';
        return;
      }
      if (t >= 5.0) {
        t = 4.99; // impossible to reach exactly 5.0 if current < 5.0
      }
      
      // Equation: (r*n + 5*x) / (n + x) = t
      // r*n + 5*x = t*n + t*x
      // x*(5 - t) = n*(t - r)
      // x = n*(t - r) / (5 - t)
      const x = Math.ceil((n * (t - r)) / (5 - t));
      displays.result.textContent = x.toString();
    }
    
    ['rating', 'reviews', 'target'].forEach(key => {
      inputs[key]?.addEventListener('input', (e) => {
        displays[key].textContent = e.target.value;
        calculate();
      });
    });
    
    calculate();
  })();
</script>
