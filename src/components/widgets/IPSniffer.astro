---
// IPSniffer.astro
---
<div class="widget-container" style="border: 1px solid oklch(var(--border)); padding: 1rem; border-radius: 0.5rem; background: oklch(var(--background));">
  <h3 style="color: oklch(var(--primary)); font-weight: bold; margin-bottom: 0.5rem;">IP Sniffer</h3>
  <pre id="ip-output" style="font-family: monospace; background: rgba(0,0,0,0.05); padding: 1rem; border-radius: 0.25rem;">Waiting for WebRTC data...</pre>
</div>

<script>
  (function() {
    const output = document.getElementById('ip-output');
    if (!output) return;

    const ips = new Set();
    const rtc = new RTCPeerConnection({ iceServers: [] });
    rtc.createDataChannel('');
    
    rtc.onicecandidate = (e) => {
      if (!e.candidate) {
        rtc.close();
        if (ips.size === 0) {
          output.textContent = 'No local IP found (possibly blocked by browser).';
        }
        return;
      }
      const ipMatch = e.candidate.candidate.match(/([0-9]{1,3}(\.[0-9]{1,3}){3}|[a-f0-9]{1,4}(:[a-f0-9]{1,4}){7})/);
      if (ipMatch) {
        ips.add(ipMatch[1]);
        output.textContent = Array.from(ips).join('\n');
      }
    };
    
    rtc.createOffer().then(offer => rtc.setLocalDescription(offer)).catch(e => {
      output.textContent = 'WebRTC error: ' + e.message;
    });
  })();
</script>
