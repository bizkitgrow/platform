---
export interface Props {
 reviews?: { author: string; company: string; text: string; rating: number }[];
}

const defaultReviews = [
 {
 author: 'Marcus Vance',
 company: 'Nexus logistics',
 text: 'Bizkitgrow bypassed sitemap conflicts and elevated our Google Business ranking within 14 days of activation.',
 rating: 5,
 },
 {
 author: 'Sarah Lin',
 company: 'Apex Networks',
 text: 'The reputation gating is flawless. All negative feedback is routed directly to our internal CRM, while 5-star reviews hit Google automatically.',
 rating: 5,
 },
];

const { reviews = defaultReviews } = Astro.props;
---

<div class="google-reviews-widget border-4 border-black p-6 bg-white text-black shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] max-w-xl mx-auto font-mono">
 <div class="border-b-2 border-black pb-4 mb-4 flex items-center justify-between">
 <div class="flex flex-col">
 <div class="text-[10px] text-gray-500 font-bold uppercase tracking-wider">// REPUTATION_TELEMETRY</div>
 <h4 class="font-black text-sm uppercase tracking-wider">VERIFIED FEEDBACK</h4>
 </div>
 <div class="flex items-center gap-1">
 <span class="text-xs font-bold bg-yellow-400 border border-black px-1.5 py-0.5">4.9 / 5.0</span>
 <span class="text-xs text-gray-500 font-bold">(142 reviews)</span>
 </div>
 </div>

 <div class="space-y-4">
 {reviews.map((r) => (
 <div class="border border-black p-4 bg-gray-50 flex flex-col space-y-2">
 <div class="flex items-center justify-between border-b border-black border-dashed pb-2">
 <div class="flex flex-col">
 <span class="text-xs font-bold uppercase tracking-tight">{r.author}</span>
 <span class="text-[9px] text-gray-500 uppercase tracking-widest font-black">{r.company}</span>
 </div>
 <div class="flex text-yellow-400">
 {Array.from({ length: r.rating }).map(() => (
 <svg class="w-4 h-4 fill-current stroke-black stroke-2"viewBox="0 0 24 24">
 <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
 </svg>
 ))}
 </div>
 </div>
 <p class="text-xs text-gray-700 italic">"{r.text}"</p>
 </div>
 ))}
 </div>

 <div class="mt-4 border-2 border-dashed border-black p-3 bg-yellow-50 text-center text-xs">
 <span class="font-bold">Active Gate Filter:</span> 4-5★ auto-published, &lt;3★ routed to support queues.
 </div>
</div>
