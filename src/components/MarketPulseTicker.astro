---
// MarketPulseTicker: Live status marquee strip
// Data is static fallback; dynamic fetch via client-side from /api/v1/market/pulse
---

<div
  class="w-full bg-canvas_accent border-y border-borders_subtle py-3.5 overflow-hidden whitespace-nowrap relative select-none z-20"
  role="marquee"
  aria-label="Live system and market status ticker"
>
  <!-- Fade edges -->
  <div class="absolute left-0 top-0 bottom-0 w-16 bg-gradient-to-r from-canvas_accent to-transparent z-10 pointer-events-none" aria-hidden="true"></div>
  <div class="absolute right-0 top-0 bottom-0 w-16 bg-gradient-to-l from-canvas_accent to-transparent z-10 pointer-events-none" aria-hidden="true"></div>

  <div class="ticker-wrap flex w-max">
    <div class="ticker-inner font-mono text-[10px] uppercase tracking-[0.12em] text-text_secondary flex items-center">
      <span class="inline-flex items-center mx-8">
        <span class="w-1.5 h-1.5 rounded-full bg-brand_cta animate-pulse mr-2" aria-hidden="true"></span>
        CONTENT PIPELINE: STABLE
      </span>
      <span class="inline-flex items-center mx-8">
        ESIM COVERAGE: <span class="text-brand_cta ml-1.5">190+ COUNTRIES</span>
      </span>
      <span class="inline-flex items-center mx-8">
        REPUTATION LATENCY: <span class="text-text_primary ml-1.5">&lt;420ms</span>
      </span>
      <span class="inline-flex items-center mx-8">
        DISTRIBUTION GATES: <span class="text-brand_cta ml-1.5">ACTIVE</span>
      </span>
      <span class="inline-flex items-center mx-8">
        AI POLISHER LAYER: <span class="text-text_primary ml-1.5">RUNNING</span>
      </span>
      <span class="inline-flex items-center mx-8">
        INFRASTRUCTURE NODE: <span class="text-brand_cta ml-1.5">CONNECTED</span>
      </span>
    </div>
    
    <!-- Duplicate for seamless loop -->
    <div class="ticker-inner font-mono text-[10px] uppercase tracking-[0.12em] text-text_secondary flex items-center" aria-hidden="true">
      <span class="inline-flex items-center mx-8">
        <span class="w-1.5 h-1.5 rounded-full bg-brand_cta animate-pulse mr-2" aria-hidden="true"></span>
        CONTENT PIPELINE: STABLE
      </span>
      <span class="inline-flex items-center mx-8">
        ESIM COVERAGE: <span class="text-brand_cta ml-1.5">190+ COUNTRIES</span>
      </span>
      <span class="inline-flex items-center mx-8">
        REPUTATION LATENCY: <span class="text-text_primary ml-1.5">&lt;420ms</span>
      </span>
      <span class="inline-flex items-center mx-8">
        DISTRIBUTION GATES: <span class="text-brand_cta ml-1.5">ACTIVE</span>
      </span>
      <span class="inline-flex items-center mx-8">
        AI POLISHER LAYER: <span class="text-text_primary ml-1.5">RUNNING</span>
      </span>
      <span class="inline-flex items-center mx-8">
        INFRASTRUCTURE NODE: <span class="text-brand_cta ml-1.5">CONNECTED</span>
      </span>
    </div>
  </div>
</div>

<style>
  .ticker-wrap {
    display: flex;
    flex-wrap: nowrap;
  }
  @media (prefers-reduced-motion: no-preference) {
    @keyframes ticker-scroll {
      0% { transform: translate3d(0, 0, 0); }
      100% { transform: translate3d(-50%, 0, 0); }
    }
    .ticker-wrap {
      animation: ticker-scroll 30s linear infinite;
    }
  }
</style>
