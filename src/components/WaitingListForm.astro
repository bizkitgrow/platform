---
interface Props {
  targetedService?: string;
}

const { targetedService = 'General' } = Astro.props;
---

<div id="waitlist" class="p-8 sm:p-12 bg-background-surface border border-border-subtle rounded-3xl shadow-sm max-w-xl mx-auto mt-20">
  <div class="text-center mb-8">
    <h2 class="text-2xl sm:text-3xl font-extrabold text-text-primary mb-3 tracking-tight">Join the Operational Perimeter</h2>
    <p class="text-sm text-text-secondary leading-relaxed">Secure system resource allocation and gain onboarding priority.</p>
  </div>

  <form id="waiting-list-form" class="space-y-4">
    <input type="hidden" name="targeted_service" value={targetedService} />
    
    <div>
      <label for="email" class="block text-xs font-semibold text-text-secondary uppercase tracking-wider mb-2">Corporate Email</label>
      <input 
        id="email"
        type="email" 
        name="email" 
        required 
        placeholder="e.g., operations@acmecorp.com" 
        class="w-full h-11 px-4 rounded-xl border border-border-subtle focus:border-interactive-hover focus:ring-1 focus:ring-interactive-hover outline-none text-sm transition-all bg-background-base text-text-primary"
      />
    </div>

    <div>
      <label for="business_name" class="block text-xs font-semibold text-text-secondary uppercase tracking-wider mb-2">Business Identity</label>
      <input 
        id="business_name"
        type="text" 
        name="business_name" 
        placeholder="e.g., Acme Operations Ltd" 
        class="w-full h-11 px-4 rounded-xl border border-border-subtle focus:border-interactive-hover focus:ring-1 focus:ring-interactive-hover outline-none text-sm transition-all bg-background-base text-text-primary"
      />
    </div>

    <button 
      id="submit-btn"
      type="submit" 
      class="w-full h-12 rounded-xl bg-interactive-normal hover:bg-interactive-hover text-text-inverse text-sm font-bold shadow-sm transition-all flex items-center justify-center gap-2 disabled:opacity-70 disabled:cursor-not-allowed"
    >
      <span id="btn-text">Initialize Onboarding Queue</span>
      <svg id="btn-spinner" class="animate-spin hidden w-4 h-4 text-text-inverse" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
    </button>
  </form>

  <div id="form-response" class="mt-4 text-center text-xs font-medium hidden"></div>
</div>

<script is:inline>
  const form = document.getElementById('waiting-list-form');
  const responseDiv = document.getElementById('form-response');
  const submitBtn = document.getElementById('submit-btn');
  const btnText = document.getElementById('btn-text');
  const btnSpinner = document.getElementById('btn-spinner');

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const formData = new FormData(form);
      const email = formData.get('email');
      const business_name = formData.get('business_name');
      const targeted_service = formData.get('targeted_service');

      // State: Loading
      responseDiv.classList.add('hidden');
      responseDiv.classList.remove('text-red-600', 'text-teal-600');
      submitBtn.disabled = true;
      btnText.textContent = 'Processing...';
      btnSpinner.classList.remove('hidden');

      try {
        const res = await fetch('/api/waiting-list', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({
            email,
            business_name,
            targeted_service
          })
        });

        const data = await res.json();
        
        // State: Done
        submitBtn.disabled = false;
        btnText.textContent = 'Initialize Onboarding Queue';
        btnSpinner.classList.add('hidden');
        responseDiv.classList.remove('hidden');
        
        if (res.ok) {
          responseDiv.classList.add('text-teal-600');
          responseDiv.textContent = 'Priority access secured. Please check your email.';
          form.reset();
        } else {
          responseDiv.classList.add('text-red-600');
          responseDiv.textContent = data.error || 'System error occurred. Please refresh the page.';
        }
      } catch (err) {
        submitBtn.disabled = false;
        btnText.textContent = 'Initialize Onboarding Queue';
        btnSpinner.classList.add('hidden');
        responseDiv.classList.remove('hidden');
        responseDiv.classList.add('text-red-600');
        responseDiv.textContent = 'Connection lost. Please ensure your device is connected to the internet.';
      }
    });
  }
</script>
