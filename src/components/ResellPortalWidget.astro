---
export interface Props {
 productSku?: string;
 theme?: string;
 resellportalStatus?: string;
}

import { siteConfig } from '~/config/site';

const {
 productSku = 'ai-blog-generator',
 theme = 'dark-brutalist',
 resellportalStatus = 'pending',
} = Astro.props;
---

{resellportalStatus === 'active' ? (
 <div class="resellportal-widget bg-black text-white p-6 border-4 border-green-500 my-8"
 data-product={productSku}
 data-brand="bizkitgrow"
 data-theme={theme}>
 <div class="flex items-center justify-between">
 <div>
 <h3 class="text-xl font-bold uppercase tracking-widest font-mono text-green-500 flex items-center gap-2">
 <svg class="w-6 h-6"fill="currentColor"viewBox="0 0 20 20"><path fill-rule="evenodd"d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"clip-rule="evenodd"></path></svg>
 Service Activated
 </h3>
 <p class="text-sm mt-2 text-gray-400">Your SaaS instance is provisioned and running successfully.</p>
 </div>
 <a href={`https://panel.resellportal.com/manage/${productSku}`} class="bg-white text-black px-6 py-3 font-bold uppercase tracking-widest hover:bg-green-500 hover:text-white transition-colors duration-200">
 Manage Instance
 </a>
 </div>
 </div>
) : (
 <div class="resellportal-widget bg-black text-white p-6 border-4 border-white my-8"
 data-product={productSku}
 data-brand="bizkitgrow"
 data-theme={theme}>
 <div class="flex flex-col md:flex-row items-center justify-between gap-6">
 <div>
 <h3 class="text-xl font-bold uppercase tracking-widest font-mono">Unlock Full Architecture</h3>
 <p class="text-sm mt-2 text-gray-400">Deploy your own enterprise-grade {productSku} infrastructure instantly.</p>
 </div>
 <a href={`${siteConfig.shopUrl}/checkout/${productSku}`} class="bg-white text-black px-8 py-4 font-bold uppercase tracking-widest text-sm hover:bg-gray-200 transition-colors duration-200 w-full md:w-auto text-center"rel="noopener">
 Provision Now
 </a>
 </div>
 </div>
)}

<style>
 .resellportal-widget {
 font-family: 'JetBrains Mono', 'Outfit', sans-serif;
 }
</style>
